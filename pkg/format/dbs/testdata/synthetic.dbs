<?xml version="1.0" encoding="UTF-8" ?>
<project name="synthetic" database="PostgreSQL" id="00000000-0000-0000-0000-000000000001" >
	<schema name="public" >
		<table name="artist" >
			<column name="artist_id" type="integer" mandatory="y" >
				<identity><![CDATA[GENERATED BY DEFAULT AS IDENTITY]]></identity>
			</column>
			<column name="name" type="varchar" length="120" mandatory="y" />
			<index name="pk_artist" unique="PRIMARY_KEY" >
				<column name="artist_id" />
			</index>
		</table>
		<table name="album" >
			<column name="album_id" type="integer" mandatory="y" >
				<identity><![CDATA[GENERATED BY DEFAULT AS IDENTITY]]></identity>
			</column>
			<column name="title" type="varchar" length="160" mandatory="y" />
			<column name="artist_id" type="integer" mandatory="y" />
			<index name="pk_album" unique="PRIMARY_KEY" >
				<column name="album_id" />
			</index>
			<fk name="fk_album_artist" to_schema="public" to_table="artist" delete_action="restrict" update_action="restrict" >
				<fk_column name="artist_id" pk="artist_id" />
			</fk>
		</table>
		<table name="track" >
			<column name="track_id" type="integer" mandatory="y" >
				<identity><![CDATA[GENERATED BY DEFAULT AS IDENTITY]]></identity>
			</column>
			<column name="name" type="varchar" length="200" mandatory="y" />
			<column name="album_id" type="integer" />
			<column name="milliseconds" type="integer" mandatory="y" />
			<column name="unit_price" type="numeric" length="10" decimal="2" mandatory="y" />
			<index name="pk_track" unique="PRIMARY_KEY" >
				<column name="track_id" />
			</index>
			<fk name="fk_track_album" to_schema="public" to_table="album" delete_action="restrict" update_action="restrict" >
				<fk_column name="album_id" pk="album_id" />
			</fk>
		</table>
	</schema>
	<layout name="Default Diagram" show_relation="columns" >
		<entity schema="public" name="artist" x="40" y="40" />
		<entity schema="public" name="album" x="240" y="40" />
		<entity schema="public" name="track" x="440" y="40" />
	</layout>
</project>
