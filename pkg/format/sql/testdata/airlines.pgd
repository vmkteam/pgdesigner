    <comment on="column" schema="bookings" table="tickets" name="passenger_name">Passenger name</comment>
    <comment on="column" schema="bookings" table="tickets" name="contact_data">Passenger contact information</comment>
  </comments>
  <layouts>
    <layout name="Default Diagram" default="true"></layout>
  </layouts>
</pgd>
