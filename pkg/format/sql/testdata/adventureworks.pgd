<?xml version="1.0" encoding="UTF-8"?>
<pgd version="1" pg-version="18" default-schema="public">
  <project name="adventureworks">
    <settings>
      <naming convention="camelCase"></naming>
      <defaults nullable="true" on-delete="restrict" on-update="restrict"></defaults>
    </settings>
  </project>
  <roles></roles>
  <tablespaces></tablespaces>
  <extensions>
    <extension name="tablefunc"></extension>
    <extension name="uuid-ossp"></extension>
  </extensions>
  <types>
    <domain name="AccountNumber" type="varchar"></domain>
    <domain name="Flag" type="boolean">
      <not-null></not-null>
    </domain>
    <domain name="Name" type="varchar"></domain>
    <domain name="NameStyle" type="boolean">
      <not-null></not-null>
    </domain>
    <domain name="OrderNumber" type="varchar"></domain>
    <domain name="Phone" type="varchar"></domain>
  </types>
  <sequences>
    <sequence name="department_departmentid_seq" schema="humanresources" start="1" increment="1" cache="1"></sequence>
    <sequence name="jobcandidate_jobcandidateid_seq" schema="humanresources" start="1" increment="1" cache="1"></sequence>
    <sequence name="shift_shiftid_seq" schema="humanresources" start="1" increment="1" cache="1"></sequence>
    <sequence name="address_addressid_seq" schema="person" start="1" increment="1" cache="1"></sequence>
    <sequence name="addresstype_addresstypeid_seq" schema="person" start="1" increment="1" cache="1"></sequence>
    <sequence name="businessentity_businessentityid_seq" schema="person" start="1" increment="1" cache="1"></sequence>
    <sequence name="contacttype_contacttypeid_seq" schema="person" start="1" increment="1" cache="1"></sequence>
    <sequence name="emailaddress_emailaddressid_seq" schema="person" start="1" increment="1" cache="1"></sequence>
    <sequence name="phonenumbertype_phonenumbertypeid_seq" schema="person" start="1" increment="1" cache="1"></sequence>
    <sequence name="stateprovince_stateprovinceid_seq" schema="person" start="1" increment="1" cache="1"></sequence>
    <sequence name="billofmaterials_billofmaterialsid_seq" schema="production" start="1" increment="1" cache="1"></sequence>
    <sequence name="illustration_illustrationid_seq" schema="production" start="1" increment="1" cache="1"></sequence>
    <sequence name="location_locationid_seq" schema="production" start="1" increment="1" cache="1"></sequence>
    <sequence name="product_productid_seq" schema="production" start="1" increment="1" cache="1"></sequence>
    <sequence name="productcategory_productcategoryid_seq" schema="production" start="1" increment="1" cache="1"></sequence>
    <sequence name="productdescription_productdescriptionid_seq" schema="production" start="1" increment="1" cache="1"></sequence>
    <sequence name="productmodel_productmodelid_seq" schema="production" start="1" increment="1" cache="1"></sequence>
    <sequence name="productphoto_productphotoid_seq" schema="production" start="1" increment="1" cache="1"></sequence>
    <sequence name="productreview_productreviewid_seq" schema="production" start="1" increment="1" cache="1"></sequence>
    <sequence name="productsubcategory_productsubcategoryid_seq" schema="production" start="1" increment="1" cache="1"></sequence>
    <sequence name="scrapreason_scrapreasonid_seq" schema="production" start="1" increment="1" cache="1"></sequence>
    <sequence name="transactionhistory_transactionid_seq" schema="production" start="1" increment="1" cache="1"></sequence>
    <sequence name="workorder_workorderid_seq" schema="production" start="1" increment="1" cache="1"></sequence>
    <sequence name="purchaseorderdetail_purchaseorderdetailid_seq" schema="purchasing" start="1" increment="1" cache="1"></sequence>
    <sequence name="purchaseorderheader_purchaseorderid_seq" schema="purchasing" start="1" increment="1" cache="1"></sequence>
    <sequence name="shipmethod_shipmethodid_seq" schema="purchasing" start="1" increment="1" cache="1"></sequence>
    <sequence name="creditcard_creditcardid_seq" schema="sales" start="1" increment="1" cache="1"></sequence>
    <sequence name="currencyrate_currencyrateid_seq" schema="sales" start="1" increment="1" cache="1"></sequence>
    <sequence name="customer_customerid_seq" schema="sales" start="1" increment="1" cache="1"></sequence>
    <sequence name="salesorderdetail_salesorderdetailid_seq" schema="sales" start="1" increment="1" cache="1"></sequence>
    <sequence name="salesorderheader_salesorderid_seq" schema="sales" start="1" increment="1" cache="1"></sequence>
    <sequence name="salesreason_salesreasonid_seq" schema="sales" start="1" increment="1" cache="1"></sequence>
    <sequence name="salestaxrate_salestaxrateid_seq" schema="sales" start="1" increment="1" cache="1"></sequence>
    <sequence name="salesterritory_territoryid_seq" schema="sales" start="1" increment="1" cache="1"></sequence>
    <sequence name="shoppingcartitem_shoppingcartitemid_seq" schema="sales" start="1" increment="1" cache="1"></sequence>
    <sequence name="specialoffer_specialofferid_seq" schema="sales" start="1" increment="1" cache="1"></sequence>
  </sequences>
  <schema name="hr"></schema>
  <schema name="humanresources">
    <table name="department">
      <column name="departmentid" type="integer" nullable="false"></column>
      <column name="name" type="Name" nullable="false"></column>
      <column name="groupname" type="Name" nullable="false"></column>
      <column name="modifieddate" type="timestamp" nullable="false" default="now()"></column>
      <pk name="PK_Department_DepartmentID">
        <column name="departmentid"></column>
      </pk>
    </table>
    <table name="employee">
      <column name="businessentityid" type="integer" nullable="false"></column>
      <column name="nationalidnumber" type="varchar" length="15" nullable="false"></column>
      <column name="loginid" type="varchar" length="256" nullable="false"></column>
      <column name="jobtitle" type="varchar" length="50" nullable="false"></column>
      <column name="birthdate" type="date" nullable="false"></column>
      <column name="maritalstatus" type="bpchar" nullable="false"></column>
      <column name="gender" type="bpchar" nullable="false"></column>
      <column name="hiredate" type="date" nullable="false"></column>
      <column name="salariedflag" type="Flag" nullable="false" default="true"></column>
      <column name="vacationhours" type="smallint" nullable="false" default="0"></column>
      <column name="sickleavehours" type="smallint" nullable="false" default="0"></column>
      <column name="currentflag" type="Flag" nullable="false" default="true"></column>
      <column name="rowguid" type="uuid" nullable="false" default="public.uuid_generate_v1()"></column>
      <column name="modifieddate" type="timestamp" nullable="false" default="now()"></column>
      <column name="organizationnode" type="varchar" default="&#39;/&#39;::varchar"></column>
      <pk name="PK_Employee_BusinessEntityID">
        <column name="businessentityid"></column>
      </pk>
      <fk name="FK_Employee_Person_BusinessEntityID" to-table="person.person" on-delete="no action" on-update="no action">
        <column name="businessentityid" references="businessentityid"></column>
      </fk>
      <check name="CK_Employee_BirthDate"><![CDATA[birthdate >= '1930-01-01'::date AND birthdate <= (now() - '18 years'::interval)]]></check>
      <check name="CK_Employee_Gender"><![CDATA[upper(gender::text) = ANY(ARRAY['M'::text, 'F'::text])]]></check>
      <check name="CK_Employee_HireDate"><![CDATA[hiredate >= '1996-07-01'::date AND hiredate <= (now() + '1 day'::interval)]]></check>
      <check name="CK_Employee_MaritalStatus"><![CDATA[upper(maritalstatus::text) = ANY(ARRAY['M'::text, 'S'::text])]]></check>
      <check name="CK_Employee_SickLeaveHours"><![CDATA[sickleavehours >= 0 AND sickleavehours <= 120]]></check>
      <check name="CK_Employee_VacationHours"><![CDATA[vacationhours >= '-40'::int AND vacationhours <= 240]]></check>
    </table>
    <table name="employeedepartmenthistory">
      <column name="businessentityid" type="integer" nullable="false"></column>
      <column name="departmentid" type="smallint" nullable="false"></column>
      <column name="shiftid" type="smallint" nullable="false"></column>
      <column name="startdate" type="date" nullable="false"></column>
      <column name="enddate" type="date"></column>
      <column name="modifieddate" type="timestamp" nullable="false" default="now()"></column>
      <pk name="PK_EmployeeDepartmentHistory_BusinessEntityID_StartDate_Departm">
        <column name="businessentityid"></column>
        <column name="startdate"></column>
        <column name="departmentid"></column>
        <column name="shiftid"></column>
      </pk>
      <fk name="FK_EmployeeDepartmentHistory_Department_DepartmentID" to-table="humanresources.department" on-delete="no action" on-update="no action">
        <column name="departmentid" references="departmentid"></column>
      </fk>
      <fk name="FK_EmployeeDepartmentHistory_Employee_BusinessEntityID" to-table="humanresources.employee" on-delete="no action" on-update="no action">
        <column name="businessentityid" references="businessentityid"></column>
      </fk>
      <fk name="FK_EmployeeDepartmentHistory_Shift_ShiftID" to-table="humanresources.shift" on-delete="no action" on-update="no action">
        <column name="shiftid" references="shiftid"></column>
      </fk>
      <check name="CK_EmployeeDepartmentHistory_EndDate"><![CDATA[enddate >= startdate OR enddate IS NULL]]></check>
    </table>
    <table name="employeepayhistory">
      <column name="businessentityid" type="integer" nullable="false"></column>
      <column name="ratechangedate" type="timestamp" nullable="false"></column>
      <column name="rate" type="numeric" nullable="false"></column>
      <column name="payfrequency" type="smallint" nullable="false"></column>
      <column name="modifieddate" type="timestamp" nullable="false" default="now()"></column>
      <pk name="PK_EmployeePayHistory_BusinessEntityID_RateChangeDate">
        <column name="businessentityid"></column>
        <column name="ratechangedate"></column>
      </pk>
      <fk name="FK_EmployeePayHistory_Employee_BusinessEntityID" to-table="humanresources.employee" on-delete="no action" on-update="no action">
        <column name="businessentityid" references="businessentityid"></column>
      </fk>
      <check name="CK_EmployeePayHistory_PayFrequency"><![CDATA[payfrequency = ANY(ARRAY[1, 2])]]></check>
      <check name="CK_EmployeePayHistory_Rate"><![CDATA[rate >= 6.50 AND rate <= 200.00]]></check>
    </table>
    <table name="jobcandidate">
      <column name="jobcandidateid" type="integer" nullable="false"></column>
      <column name="businessentityid" type="integer"></column>
      <column name="resume" type="xml"></column>
      <column name="modifieddate" type="timestamp" nullable="false" default="now()"></column>
      <pk name="PK_JobCandidate_JobCandidateID">
        <column name="jobcandidateid"></column>
      </pk>
      <fk name="FK_JobCandidate_Employee_BusinessEntityID" to-table="humanresources.employee" on-delete="no action" on-update="no action">
        <column name="businessentityid" references="businessentityid"></column>
      </fk>
    </table>
    <table name="shift">
      <column name="shiftid" type="integer" nullable="false"></column>
      <column name="name" type="Name" nullable="false"></column>
      <column name="starttime" type="time" nullable="false"></column>
      <column name="endtime" type="time" nullable="false"></column>
      <column name="modifieddate" type="timestamp" nullable="false" default="now()"></column>
      <pk name="PK_Shift_ShiftID">
        <column name="shiftid"></column>
      </pk>
    </table>
  </schema>
  <schema name="pe"></schema>
  <schema name="person">
    <table name="address">
      <column name="addressid" type="integer" nullable="false"></column>
      <column name="addressline1" type="varchar" length="60" nullable="false"></column>
      <column name="addressline2" type="varchar" length="60"></column>
      <column name="city" type="varchar" length="30" nullable="false"></column>
      <column name="stateprovinceid" type="integer" nullable="false"></column>
      <column name="postalcode" type="varchar" length="15" nullable="false"></column>
      <column name="spatiallocation" type="bytea"></column>
      <column name="rowguid" type="uuid" nullable="false" default="public.uuid_generate_v1()"></column>
      <column name="modifieddate" type="timestamp" nullable="false" default="now()"></column>
      <pk name="PK_Address_AddressID">
        <column name="addressid"></column>
      </pk>
      <fk name="FK_Address_StateProvince_StateProvinceID" to-table="person.stateprovince" on-delete="no action" on-update="no action">
        <column name="stateprovinceid" references="stateprovinceid"></column>
      </fk>
    </table>
    <table name="addresstype">
      <column name="addresstypeid" type="integer" nullable="false"></column>
      <column name="name" type="Name" nullable="false"></column>
      <column name="rowguid" type="uuid" nullable="false" default="public.uuid_generate_v1()"></column>
      <column name="modifieddate" type="timestamp" nullable="false" default="now()"></column>
      <pk name="PK_AddressType_AddressTypeID">
        <column name="addresstypeid"></column>
      </pk>
    </table>
    <table name="businessentity">
      <column name="businessentityid" type="integer" nullable="false"></column>
      <column name="rowguid" type="uuid" nullable="false" default="public.uuid_generate_v1()"></column>
      <column name="modifieddate" type="timestamp" nullable="false" default="now()"></column>
      <pk name="PK_BusinessEntity_BusinessEntityID">
        <column name="businessentityid"></column>
      </pk>
    </table>
    <table name="businessentityaddress">
      <column name="businessentityid" type="integer" nullable="false"></column>
      <column name="addressid" type="integer" nullable="false"></column>
      <column name="addresstypeid" type="integer" nullable="false"></column>
      <column name="rowguid" type="uuid" nullable="false" default="public.uuid_generate_v1()"></column>
      <column name="modifieddate" type="timestamp" nullable="false" default="now()"></column>
      <pk name="PK_BusinessEntityAddress_BusinessEntityID_AddressID_AddressType">
        <column name="businessentityid"></column>
        <column name="addressid"></column>
        <column name="addresstypeid"></column>
      </pk>
      <fk name="FK_BusinessEntityAddress_AddressType_AddressTypeID" to-table="person.addresstype" on-delete="no action" on-update="no action">
        <column name="addresstypeid" references="addresstypeid"></column>
      </fk>
      <fk name="FK_BusinessEntityAddress_Address_AddressID" to-table="person.address" on-delete="no action" on-update="no action">
        <column name="addressid" references="addressid"></column>
      </fk>
      <fk name="FK_BusinessEntityAddress_BusinessEntity_BusinessEntityID" to-table="person.businessentity" on-delete="no action" on-update="no action">
        <column name="businessentityid" references="businessentityid"></column>
      </fk>
    </table>
    <table name="businessentitycontact">
      <column name="businessentityid" type="integer" nullable="false"></column>
      <column name="personid" type="integer" nullable="false"></column>
      <column name="contacttypeid" type="integer" nullable="false"></column>
      <column name="rowguid" type="uuid" nullable="false" default="public.uuid_generate_v1()"></column>
      <column name="modifieddate" type="timestamp" nullable="false" default="now()"></column>
      <pk name="PK_BusinessEntityContact_BusinessEntityID_PersonID_ContactTypeI">
        <column name="businessentityid"></column>
        <column name="personid"></column>
        <column name="contacttypeid"></column>
      </pk>
      <fk name="FK_BusinessEntityContact_BusinessEntity_BusinessEntityID" to-table="person.businessentity" on-delete="no action" on-update="no action">
        <column name="businessentityid" references="businessentityid"></column>
      </fk>
      <fk name="FK_BusinessEntityContact_ContactType_ContactTypeID" to-table="person.contacttype" on-delete="no action" on-update="no action">
        <column name="contacttypeid" references="contacttypeid"></column>
      </fk>
      <fk name="FK_BusinessEntityContact_Person_PersonID" to-table="person.person" on-delete="no action" on-update="no action">
        <column name="personid" references="businessentityid"></column>
      </fk>
    </table>
    <table name="contacttype">
      <column name="contacttypeid" type="integer" nullable="false"></column>
      <column name="name" type="Name" nullable="false"></column>
      <column name="modifieddate" type="timestamp" nullable="false" default="now()"></column>
      <pk name="PK_ContactType_ContactTypeID">
        <column name="contacttypeid"></column>
      </pk>
    </table>
    <table name="countryregion">
      <column name="countryregioncode" type="varchar" length="3" nullable="false"></column>
      <column name="name" type="Name" nullable="false"></column>
      <column name="modifieddate" type="timestamp" nullable="false" default="now()"></column>
      <pk name="PK_CountryRegion_CountryRegionCode">
        <column name="countryregioncode"></column>
      </pk>
    </table>
    <table name="emailaddress">
      <column name="businessentityid" type="integer" nullable="false"></column>
      <column name="emailaddressid" type="integer" nullable="false"></column>
      <column name="emailaddress" type="varchar" length="50"></column>
      <column name="rowguid" type="uuid" nullable="false" default="public.uuid_generate_v1()"></column>
      <column name="modifieddate" type="timestamp" nullable="false" default="now()"></column>
      <pk name="PK_EmailAddress_BusinessEntityID_EmailAddressID">
        <column name="businessentityid"></column>
        <column name="emailaddressid"></column>
      </pk>
      <fk name="FK_EmailAddress_Person_BusinessEntityID" to-table="person.person" on-delete="no action" on-update="no action">
        <column name="businessentityid" references="businessentityid"></column>
      </fk>
    </table>
    <table name="password">
      <column name="businessentityid" type="integer" nullable="false"></column>
      <column name="passwordhash" type="varchar" length="128" nullable="false"></column>
      <column name="passwordsalt" type="varchar" length="10" nullable="false"></column>
      <column name="rowguid" type="uuid" nullable="false" default="public.uuid_generate_v1()"></column>
      <column name="modifieddate" type="timestamp" nullable="false" default="now()"></column>
      <pk name="PK_Password_BusinessEntityID">
        <column name="businessentityid"></column>
      </pk>
      <fk name="FK_Password_Person_BusinessEntityID" to-table="person.person" on-delete="no action" on-update="no action">
        <column name="businessentityid" references="businessentityid"></column>
      </fk>
    </table>
    <table name="person">
      <column name="businessentityid" type="integer" nullable="false"></column>
      <column name="persontype" type="bpchar" nullable="false"></column>
      <column name="namestyle" type="NameStyle" nullable="false" default="false"></column>
      <column name="title" type="varchar" length="8"></column>
      <column name="firstname" type="Name" nullable="false"></column>
      <column name="middlename" type="Name"></column>
      <column name="lastname" type="Name" nullable="false"></column>
      <column name="suffix" type="varchar" length="10"></column>
      <column name="emailpromotion" type="integer" nullable="false" default="0"></column>
      <column name="additionalcontactinfo" type="xml"></column>
      <column name="demographics" type="xml"></column>
      <column name="rowguid" type="uuid" nullable="false" default="public.uuid_generate_v1()"></column>
      <column name="modifieddate" type="timestamp" nullable="false" default="now()"></column>
      <pk name="PK_Person_BusinessEntityID">
        <column name="businessentityid"></column>
      </pk>
      <fk name="FK_Person_BusinessEntity_BusinessEntityID" to-table="person.businessentity" on-delete="no action" on-update="no action">
        <column name="businessentityid" references="businessentityid"></column>
      </fk>
      <check name="CK_Person_EmailPromotion"><![CDATA[emailpromotion >= 0 AND emailpromotion <= 2]]></check>
      <check name="CK_Person_PersonType"><![CDATA[persontype IS NULL OR upper(persontype::text) = ANY(ARRAY['SC'::text, 'VC'::text, 'IN'::text, 'EM'::text, 'SP'::text, 'GC'::text])]]></check>
    </table>
    <table name="personphone">
      <column name="businessentityid" type="integer" nullable="false"></column>
      <column name="phonenumber" type="Phone" nullable="false"></column>
      <column name="phonenumbertypeid" type="integer" nullable="false"></column>
      <column name="modifieddate" type="timestamp" nullable="false" default="now()"></column>
      <pk name="PK_PersonPhone_BusinessEntityID_PhoneNumber_PhoneNumberTypeID">
        <column name="businessentityid"></column>
        <column name="phonenumber"></column>
        <column name="phonenumbertypeid"></column>
      </pk>
      <fk name="FK_PersonPhone_Person_BusinessEntityID" to-table="person.person" on-delete="no action" on-update="no action">
        <column name="businessentityid" references="businessentityid"></column>
      </fk>
      <fk name="FK_PersonPhone_PhoneNumberType_PhoneNumberTypeID" to-table="person.phonenumbertype" on-delete="no action" on-update="no action">
        <column name="phonenumbertypeid" references="phonenumbertypeid"></column>
      </fk>
    </table>
    <table name="phonenumbertype">
      <column name="phonenumbertypeid" type="integer" nullable="false"></column>
      <column name="name" type="Name" nullable="false"></column>
      <column name="modifieddate" type="timestamp" nullable="false" default="now()"></column>
      <pk name="PK_PhoneNumberType_PhoneNumberTypeID">
        <column name="phonenumbertypeid"></column>
      </pk>
    </table>
    <table name="stateprovince">
      <column name="stateprovinceid" type="integer" nullable="false"></column>
      <column name="stateprovincecode" type="bpchar" nullable="false"></column>
      <column name="countryregioncode" type="varchar" length="3" nullable="false"></column>
      <column name="isonlystateprovinceflag" type="Flag" nullable="false" default="true"></column>
      <column name="name" type="Name" nullable="false"></column>
      <column name="territoryid" type="integer" nullable="false"></column>
      <column name="rowguid" type="uuid" nullable="false" default="public.uuid_generate_v1()"></column>
      <column name="modifieddate" type="timestamp" nullable="false" default="now()"></column>
      <pk name="PK_StateProvince_StateProvinceID">
        <column name="stateprovinceid"></column>
      </pk>
      <fk name="FK_StateProvince_CountryRegion_CountryRegionCode" to-table="person.countryregion" on-delete="no action" on-update="no action">
        <column name="countryregioncode" references="countryregioncode"></column>
      </fk>
      <fk name="FK_StateProvince_SalesTerritory_TerritoryID" to-table="sales.salesterritory" on-delete="no action" on-update="no action">
        <column name="territoryid" references="territoryid"></column>
      </fk>
    </table>
    <index name="ix_vstateprovincecountryregion" table="vstateprovincecountryregion" unique="true">
      <column name="stateprovinceid"></column>
      <column name="countryregioncode"></column>
    </index>
  </schema>
  <schema name="pr"></schema>
  <schema name="production">
    <table name="billofmaterials">
      <column name="billofmaterialsid" type="integer" nullable="false"></column>
      <column name="productassemblyid" type="integer"></column>
      <column name="componentid" type="integer" nullable="false"></column>
      <column name="startdate" type="timestamp" nullable="false" default="now()"></column>
      <column name="enddate" type="timestamp"></column>
      <column name="unitmeasurecode" type="bpchar" nullable="false"></column>
      <column name="bomlevel" type="smallint" nullable="false"></column>
      <column name="perassemblyqty" type="numeric" precision="8" scale="2" nullable="false" default="1.00"></column>
      <column name="modifieddate" type="timestamp" nullable="false" default="now()"></column>
      <pk name="PK_BillOfMaterials_BillOfMaterialsID">
        <column name="billofmaterialsid"></column>
      </pk>
      <fk name="FK_BillOfMaterials_Product_ComponentID" to-table="production.product" on-delete="no action" on-update="no action">
        <column name="componentid" references="productid"></column>
      </fk>
      <fk name="FK_BillOfMaterials_Product_ProductAssemblyID" to-table="production.product" on-delete="no action" on-update="no action">
        <column name="productassemblyid" references="productid"></column>
      </fk>
      <fk name="FK_BillOfMaterials_UnitMeasure_UnitMeasureCode" to-table="production.unitmeasure" on-delete="no action" on-update="no action">
        <column name="unitmeasurecode" references="unitmeasurecode"></column>
      </fk>
      <check name="CK_BillOfMaterials_BOMLevel"><![CDATA[(productassemblyid IS NULL AND bomlevel = 0 AND perassemblyqty = 1.00) OR (productassemblyid IS NOT NULL AND bomlevel >= 1)]]></check>
      <check name="CK_BillOfMaterials_EndDate"><![CDATA[enddate > startdate OR enddate IS NULL]]></check>
      <check name="CK_BillOfMaterials_PerAssemblyQty"><![CDATA[perassemblyqty >= 1.00]]></check>
      <check name="CK_BillOfMaterials_ProductAssemblyID"><![CDATA[productassemblyid <> componentid]]></check>
    </table>
    <table name="culture">
      <column name="cultureid" type="bpchar" nullable="false"></column>
      <column name="name" type="Name" nullable="false"></column>
      <column name="modifieddate" type="timestamp" nullable="false" default="now()"></column>
      <pk name="PK_Culture_CultureID">
        <column name="cultureid"></column>
      </pk>
    </table>
    <table name="document">
      <column name="title" type="varchar" length="50" nullable="false"></column>
      <column name="owner" type="integer" nullable="false"></column>
      <column name="folderflag" type="Flag" nullable="false" default="false"></column>
