</STOREDPROC>

<STOREDPROC ID="137145" Name="_group_concat" SchemaOID="0" SchemaName="public" OwnerID="0" OwnerName="" XPos="290" YPos="1740" LineColor="8388608" BackColor="13499135" FontColor="0" Comments="" Description="" Annotation="" BeginScript="" EndScript="" Secure="0" SFBody="\nSELECT CASE\n  WHEN $2 IS NULL THEN $1\n  WHEN $1 IS NULL THEN $2\n  ELSE $1 || \a, \a || $2\nEND\n" BodyBrackets="$BODY$" Language="sql" ReturnSet="0" Returns="text" ReturnsOID="25" ObjectFile="" LinkSymbol="" Generate="1" Strict="0" Window="0" LeakProof="0" EvaluationType="2" ResultRows="0" ExecutionCost="100" ParallelType="0" >
