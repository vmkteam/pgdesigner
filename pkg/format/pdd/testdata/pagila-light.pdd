</PARAMETER>
</PARAMETERS>
</STOREDPROC>

<STOREDPROC ID="137146" Name="group_concat" SchemaOID="0" SchemaName="public" OwnerID="0" OwnerName="" XPos="540" YPos="1660" LineColor="8388608" BackColor="13499135" FontColor="0" Comments="" Description="" Annotation="" BeginScript="" EndScript="" Secure="0" SFBody="" BodyBrackets="$BODY$" Language="internal" ReturnSet="0" Returns="text" ReturnsOID="25" ObjectFile="" LinkSymbol="" Generate="1" Strict="0" Window="0" LeakProof="0" EvaluationType="2" ResultRows="0" ExecutionCost="1" ParallelType="0" >
