<STOREDPROC ID="137316" Name="film_in_stock" SchemaOID="0" SchemaName="public" OwnerID="0" OwnerName="" XPos="40" YPos="1840" LineColor="8388608" BackColor="13499135" FontColor="0" Comments="" Description="" Annotation="" BeginScript="" EndScript="" Secure="0" SFBody="\n     SELECT inventory_id\n     FROM inventory\n     WHERE film_id = $1\n     AND store_id = $2\n     AND inventory_in_stock(inventory_id);\n" BodyBrackets="$BODY$" Language="sql" ReturnSet="1" Returns="int4" ReturnsOID="23" ObjectFile="" LinkSymbol="" Generate="1" Strict="0" Window="0" LeakProof="0" EvaluationType="2" ResultRows="1000" ExecutionCost="100" ParallelType="0" >
<PARAMETERS>
<PARAMETER ID="1424" Name="p_film_id" Pos="1" ParamType="0" Datatype="23" Type="int4" Default="" >
</PARAMETER>
<PARAMETER ID="1425" Name="p_store_id" Pos="2" ParamType="0" Datatype="23" Type="int4" Default="" >
</PARAMETER>
<PARAMETER ID="1426" Name="p_film_count" Pos="3" ParamType="1" Datatype="23" Type="int4" Default="" >
</PARAMETER>
</PARAMETERS>
</STOREDPROC>

<STOREDPROC ID="137317" Name="film_not_in_stock" SchemaOID="0" SchemaName="public" OwnerID="0" OwnerName="" XPos="200" YPos="1840" LineColor="8388608" BackColor="13499135" FontColor="0" Comments="" Description="" Annotation="" BeginScript="" EndScript="" Secure="0" SFBody="\n    SELECT inventory_id\n    FROM inventory\n    WHERE film_id = $1\n    AND store_id = $2\n    AND NOT inventory_in_stock(inventory_id);\n" BodyBrackets="$BODY$" Language="sql" ReturnSet="1" Returns="int4" ReturnsOID="23" ObjectFile="" LinkSymbol="" Generate="1" Strict="0" Window="0" LeakProof="0" EvaluationType="2" ResultRows="1000" ExecutionCost="100" ParallelType="0" >
<PARAMETERS>
<PARAMETER ID="1427" Name="p_film_id" Pos="1" ParamType="0" Datatype="23" Type="int4" Default="" >
</PARAMETER>
<PARAMETER ID="1428" Name="p_store_id" Pos="2" ParamType="0" Datatype="23" Type="int4" Default="" >
</PARAMETER>
<PARAMETER ID="1429" Name="p_film_count" Pos="3" ParamType="1" Datatype="23" Type="int4" Default="" >
</PARAMETER>
</PARAMETERS>
</STOREDPROC>

<STOREDPROC ID="137318" Name="get_customer_balance" SchemaOID="0" SchemaName="public" OwnerID="0" OwnerName="" XPos="410" YPos="1740" LineColor="8388608" BackColor="13499135" FontColor="0" Comments="" Description="" Annotation="" BeginScript="" EndScript="" Secure="0" SFBody="\n       --#OK, WE NEED TO CALCULATE THE CURRENT BALANCE GIVEN A CUSTOMER_ID AND A DATE\n       --#THAT WE WANT THE BALANCE TO BE EFFECTIVE FOR. THE BALANCE IS:\n       --#   1) RENTAL FEES FOR ALL PREVIOUS RENTALS\n       --#   2) ONE DOLLAR FOR EVERY DAY THE PREVIOUS RENTALS ARE OVERDUE\n       --#   3) IF A FILM IS MORE THAN RENTAL_DURATION * 2 OVERDUE, CHARGE THE REPLACEMENT_COST\n       --#   4) SUBTRACT ALL PAYMENTS MADE BEFORE THE DATE SPECIFIED\nDECLARE\n    v_rentfees DECIMAL(5,2); --#FEES PAID TO RENT THE VIDEOS INITIALLY\n    v_overfees INTEGER;      --#LATE FEES FOR PRIOR RENTALS\n    v_payments DECIMAL(5,2); --#SUM OF PAYMENTS MADE PREVIOUSLY\nBEGIN\n    SELECT COALESCE(SUM(film.rental_rate),0) INTO v_rentfees\n    FROM film, inventory, rental\n    WHERE film.film_id = inventory.film_id\n      AND inventory.inventory_id = rental.inventory_id\n      AND rental.rental_date \k= p_effective_date\n      AND rental.customer_id = p_customer_id;\n\n    SELECT COALESCE(SUM(IF((rental.return_date - rental.rental_date) \g (film.rental_duration * \a1 day\a::interval),\n        ((rental.return_date - rental.rental_date) - (film.rental_duration * \a1 day\a::interval)),0)),0) INTO v_overfees\n    FROM rental, inventory, film\n    WHERE film.film_id = inventory.film_id\n      AND inventory.inventory_id = rental.inventory_id\n      AND rental.rental_date \k= p_effective_date\n      AND rental.customer_id = p_customer_id;\n\n    SELECT COALESCE(SUM(payment.amount),0) INTO v_payments\n    FROM payment\n    WHERE payment.payment_date \k= p_effective_date\n    AND payment.customer_id = p_customer_id;\n\n    RETURN v_rentfees + v_overfees - v_payments;\nEND\n" BodyBrackets="$BODY$" Language="plpgsql" ReturnSet="0" Returns="numeric" ReturnsOID="1700" ObjectFile="" LinkSymbol="" Generate="1" Strict="0" Window="0" LeakProof="0" EvaluationType="2" ResultRows="0" ExecutionCost="100" ParallelType="0" >
<PARAMETERS>
<PARAMETER ID="1430" Name="p_customer_id" Pos="1" ParamType="0" Datatype="23" Type="int4" Default="" >
</PARAMETER>
<PARAMETER ID="1431" Name="p_effective_date" Pos="2" ParamType="0" Datatype="1114" Type="timestamp" Default="" >
</PARAMETER>
</PARAMETERS>
</STOREDPROC>

<STOREDPROC ID="137319" Name="inventory_held_by_customer" SchemaOID="0" SchemaName="public" OwnerID="0" OwnerName="" XPos="40" YPos="1660" LineColor="8388608" BackColor="13499135" FontColor="0" Comments="" Description="" Annotation="" BeginScript="" EndScript="" Secure="0" SFBody="\nDECLARE\n    v_customer_id INTEGER;\nBEGIN\n\n  SELECT customer_id INTO v_customer_id\n  FROM rental\n  WHERE return_date IS NULL\n  AND inventory_id = p_inventory_id;\n\n  RETURN v_customer_id;\nEND \n" BodyBrackets="$BODY$" Language="plpgsql" ReturnSet="0" Returns="int4" ReturnsOID="23" ObjectFile="" LinkSymbol="" Generate="1" Strict="0" Window="0" LeakProof="0" EvaluationType="2" ResultRows="0" ExecutionCost="100" ParallelType="0" >
<PARAMETERS>
<PARAMETER ID="1432" Name="p_inventory_id" Pos="1" ParamType="0" Datatype="23" Type="int4" Default="" >
</PARAMETER>
</PARAMETERS>
</STOREDPROC>

<STOREDPROC ID="137320" Name="inventory_in_stock" SchemaOID="0" SchemaName="public" OwnerID="0" OwnerName="" XPos="250" YPos="1660" LineColor="8388608" BackColor="13499135" FontColor="0" Comments="" Description="" Annotation="" BeginScript="" EndScript="" Secure="0" SFBody="\nDECLARE\n    v_rentals INTEGER;\n    v_out     INTEGER;\nBEGIN\n    -- AN ITEM IS IN-STOCK IF THERE ARE EITHER NO ROWS IN THE rental TABLE\n    -- FOR THE ITEM OR ALL ROWS HAVE return_date POPULATED\n\n    SELECT count(*) INTO v_rentals\n    FROM rental\n    WHERE inventory_id = p_inventory_id;\n\n    IF v_rentals = 0 THEN\n      RETURN TRUE;\n    END IF;\n\n    SELECT COUNT(rental_id) INTO v_out\n    FROM inventory LEFT JOIN rental USING(inventory_id)\n    WHERE inventory.inventory_id = p_inventory_id\n    AND rental.return_date IS NULL;\n\n    IF v_out \g 0 THEN\n      RETURN FALSE;\n    ELSE\n      RETURN TRUE;\n    END IF;\nEND \n" BodyBrackets="$BODY$" Language="plpgsql" ReturnSet="0" Returns="bool" ReturnsOID="16" ObjectFile="" LinkSymbol="" Generate="1" Strict="0" Window="0" LeakProof="0" EvaluationType="2" ResultRows="0" ExecutionCost="100" ParallelType="0" >
<PARAMETERS>
<PARAMETER ID="1433" Name="p_inventory_id" Pos="1" ParamType="0" Datatype="23" Type="int4" Default="" >
</PARAMETER>
</PARAMETERS>
</STOREDPROC>

<STOREDPROC ID="137321" Name="last_day" SchemaOID="0" SchemaName="public" OwnerID="0" OwnerName="" XPos="410" YPos="1660" LineColor="8388608" BackColor="13499135" FontColor="0" Comments="" Description="" Annotation="" BeginScript="" EndScript="" Secure="0" SFBody="\n  SELECT CASE\n    WHEN EXTRACT(MONTH FROM $1) = 12 THEN\n      (((EXTRACT(YEAR FROM $1) + 1) operator(pg_catalog.||) \a-01-01\a)::date - INTERVAL \a1 day\a)::date\n    ELSE\n      ((EXTRACT(YEAR FROM $1) operator(pg_catalog.||) \a-\a operator(pg_catalog.||) (EXTRACT(MONTH FROM $1) + 1) operator(pg_catalog.||) \a-01\a)::date - INTERVAL \a1 day\a)::date\n    END\n" BodyBrackets="$BODY$" Language="sql" ReturnSet="0" Returns="date" ReturnsOID="1082" ObjectFile="" LinkSymbol="" Generate="1" Strict="1" Window="0" LeakProof="0" EvaluationType="2" ResultRows="0" ExecutionCost="100" ParallelType="0" >
<PARAMETERS>
<PARAMETER ID="1434" Name="" Pos="1" ParamType="0" Datatype="1114" Type="timestamp" Default="" >
</PARAMETER>
</PARAMETERS>
</STOREDPROC>

<STOREDPROC ID="137323" Name="rewards_report" SchemaOID="0" SchemaName="public" OwnerID="0" OwnerName="" XPos="40" YPos="1740" LineColor="8388608" BackColor="13499135" FontColor="0" Comments="" Description="" Annotation="" BeginScript="" EndScript="" Secure="1" SFBody="\nDECLARE\n    last_month_start DATE;\n    last_month_end DATE;\nrr RECORD;\ntmpSQL TEXT;\nBEGIN\n\n    /* Some sanity checks... */\n    IF min_monthly_purchases = 0 THEN\n        RAISE EXCEPTION \aMinimum monthly purchases parameter must be \g 0\a;\n    END IF;\n    IF min_dollar_amount_purchased = 0.00 THEN\n        RAISE EXCEPTION \aMinimum monthly dollar amount purchased parameter must be \g $0.00\a;\n    END IF;\n\n    last_month_start := CURRENT_DATE - \a3 month\a::interval;\n    last_month_start := to_date((extract(YEAR FROM last_month_start) || \a-\a || extract(MONTH FROM last_month_start) || \a-01\a),\aYYYY-MM-DD\a);\n    last_month_end := LAST_DAY(last_month_start);\n\n    /*\n    Create a temporary storage area for Customer IDs.\n    */\n    CREATE TEMPORARY TABLE tmpCustomer (customer_id INTEGER NOT NULL PRIMARY KEY);\n\n    /*\n    Find all customers meeting the monthly purchase requirements\n    */\n\n    tmpSQL := \aINSERT INTO tmpCustomer (customer_id)\n        SELECT p.customer_id\n        FROM payment AS p\n        WHERE DATE(p.payment_date) BETWEEN \a||quote_literal(last_month_start) ||\a AND \a|| quote_literal(last_month_end) || \a\n        GROUP BY customer_id\n        HAVING SUM(p.amount) \g \a|| min_dollar_amount_purchased || \a\n        AND COUNT(customer_id) \g \a ||min_monthly_purchases ;\n\n    EXECUTE tmpSQL;\n\n    /*\n    Output ALL customer information of matching rewardees.\n    Customize output as needed.\n    */\n    FOR rr IN EXECUTE \aSELECT c.* FROM tmpCustomer AS t INNER JOIN customer AS c ON t.customer_id = c.customer_id\a LOOP\n        RETURN NEXT rr;\n    END LOOP;\n\n    /* Clean up */\n    tmpSQL := \aDROP TABLE tmpCustomer\a;\n    EXECUTE tmpSQL;\n\nRETURN;\nEND\n" BodyBrackets="$BODY$" Language="plpgsql" ReturnSet="1" Returns="int4" ReturnsOID="23" ObjectFile="" LinkSymbol="" Generate="1" Strict="0" Window="0" LeakProof="0" EvaluationType="2" ResultRows="1000" ExecutionCost="100" ParallelType="0" >
<PARAMETERS>
<PARAMETER ID="1435" Name="min_monthly_purchases" Pos="1" ParamType="0" Datatype="23" Type="int4" Default="" >
</PARAMETER>
<PARAMETER ID="1436" Name="min_dollar_amount_purchased" Pos="2" ParamType="0" Datatype="1700" Type="numeric" Default="" >
</PARAMETER>
</PARAMETERS>
</STOREDPROC>

</STOREDPROCES>

<VIEWS>
<VIEW ID="137176" Name="actor_info" SchemaOID="0" SchemaName="public" OwnerID="0" OwnerName="" XPos="410" YPos="1060" LineColor="8388608" BackColor="3329434" FontColor="0" Comments="" Description="" Annotation="" BeginScript="" EndScript="" SQLQuery="SELECT a.actor_id, a.first_name, a.last_name, group_concat(DISTINCT (((c.name)::text || \a: \a::text) || (SELECT group_concat((f.title)::text) AS group_concat FROM ((film f JOIN film_category fc ON ((f.film_id = fc.film_id))) JOIN film_actor fa ON ((f.film_id = fa.film_id))) WHERE ((fc.category_id = c.category_id) AND (fa.actor_id = a.actor_id)) GROUP BY fa.actor_id))) AS film_info FROM (((actor a LEFT JOIN film_actor fa ON ((a.actor_id = fa.actor_id))) LEFT JOIN film_category fc ON ((fa.film_id = fc.film_id))) LEFT JOIN category c ON ((fc.category_id = c.category_id))) GROUP BY a.actor_id, a.first_name, a.last_name" Columns="a.actor_id,a.first_name,a.last_name,film_info" Tables="\Afilm f\A,\Afilm_category fc\A,\Afilm_actor fa\A,\Aactor a\A,\Afilm_actor fa\A,\Afilm_category fc\A,\Acategory c\A" Temporary="0" SecurityBarrier="0" Recursive="0" Materialized="0" NoData="0" TablespaceID="0" Generate="1" ACL="" >
</VIEW>

<VIEW ID="137211" Name="customer_list" SchemaOID="0" SchemaName="public" OwnerID="0" OwnerName="" XPos="340" YPos="1360" LineColor="8388608" BackColor="3329434" FontColor="0" Comments="" Description="" Annotation="" BeginScript="" EndScript="" SQLQuery="SELECT cu.customer_id AS id, (((cu.first_name)::text || \a \a::text) || (cu.last_name)::text) AS name, a.address, a.postal_code AS \Azip code\A, a.phone, city.city, country.country, CASE WHEN cu.activebool THEN \aactive\a::text ELSE \a\a::text END AS notes, cu.store_id AS sid FROM (((customer cu JOIN address a ON ((cu.address_id = a.address_id))) JOIN city ON ((a.city_id = city.city_id))) JOIN country ON ((city.country_id = country.country_id)))" Columns="id,name,a.address,\A\A\Azip code\A\A\A,a.phone,city.city,country.country,notes,sid" Tables="\Acustomer cu\A,\Aaddress a\A,city,country" Temporary="0" SecurityBarrier="0" Recursive="0" Materialized="0" NoData="0" TablespaceID="0" Generate="1" ACL="" >
</VIEW>

<VIEW ID="137216" Name="film_list" SchemaOID="0" SchemaName="public" OwnerID="0" OwnerName="" XPos="540" YPos="1060" LineColor="8388608" BackColor="3329434" FontColor="0" Comments="" Description="" Annotation="" BeginScript="" EndScript="" SQLQuery="SELECT film.film_id AS fid, film.title, film.description, category.name AS category, film.rental_rate AS price, film.length, film.rating, group_concat((((actor.first_name)::text || \a \a::text) || (actor.last_name)::text)) AS actors FROM ((((category LEFT JOIN film_category ON ((category.category_id = film_category.category_id))) LEFT JOIN film ON ((film_category.film_id = film.film_id))) JOIN film_actor ON ((film.film_id = film_actor.film_id))) JOIN actor ON ((film_actor.actor_id = actor.actor_id))) GROUP BY film.film_id, film.title, film.description, category.name, film.rental_rate, film.length, film.rating" Columns="fid,film.title,film.description,category,price,film.length,film.rating,actors" Tables="category,film_category,film,film_actor,actor" Temporary="0" SecurityBarrier="0" Recursive="0" Materialized="0" NoData="0" TablespaceID="0" Generate="1" ACL="" >
</VIEW>

<VIEW ID="137235" Name="nicer_but_slower_film_list" SchemaOID="0" SchemaName="public" OwnerID="0" OwnerName="" XPos="50" YPos="1060" LineColor="8388608" BackColor="3329434" FontColor="0" Comments="" Description="" Annotation="" BeginScript="" EndScript="" SQLQuery="SELECT film.film_id AS fid, film.title, film.description, category.name AS category, film.rental_rate AS price, film.length, film.rating, group_concat((((upper(\Asubstring\A((actor.first_name)::text, 1, 1)) || lower(\Asubstring\A((actor.first_name)::text, 2))) || upper(\Asubstring\A((actor.last_name)::text, 1, 1))) || lower(\Asubstring\A((actor.last_name)::text, 2)))) AS actors FROM ((((category LEFT JOIN film_category ON ((category.category_id = film_category.category_id))) LEFT JOIN film ON ((film_category.film_id = film.film_id))) JOIN film_actor ON ((film.film_id = film_actor.film_id))) JOIN actor ON ((film_actor.actor_id = actor.actor_id))) GROUP BY film.film_id, film.title, film.description, category.name, film.rental_rate, film.length, film.rating" Columns="fid,film.title,film.description,category,price,film.length,film.rating,actors" Tables="category,film_category,film,film_actor,actor" Temporary="0" SecurityBarrier="0" Recursive="0" Materialized="0" NoData="0" TablespaceID="0" Generate="1" ACL="" >
</VIEW>

<VIEW ID="137283" Name="sales_by_film_category" SchemaOID="0" SchemaName="public" OwnerID="0" OwnerName="" XPos="220" YPos="1060" LineColor="8388608" BackColor="3329434" FontColor="0" Comments="" Description="" Annotation="" BeginScript="" EndScript="" SQLQuery="SELECT c.name AS category, sum(p.amount) AS total_sales FROM (((((payment p JOIN rental r ON ((p.rental_id = r.rental_id))) JOIN inventory i ON ((r.inventory_id = i.inventory_id))) JOIN film f ON ((i.film_id = f.film_id))) JOIN film_category fc ON ((f.film_id = fc.film_id))) JOIN category c ON ((fc.category_id = c.category_id))) GROUP BY c.name ORDER BY sum(p.amount) DESC" Columns="category,total_sales" Tables="\Apayment p\A,\Arental r\A,\Ainventory i\A,\Afilm f\A,\Afilm_category fc\A,\Acategory c\A" Temporary="0" SecurityBarrier="0" Recursive="0" Materialized="0" NoData="0" TablespaceID="0" Generate="1" ACL="" >
</VIEW>

<VIEW ID="137306" Name="sales_by_store" SchemaOID="0" SchemaName="public" OwnerID="0" OwnerName="" XPos="190" YPos="1360" LineColor="8388608" BackColor="3329434" FontColor="0" Comments="" Description="" Annotation="" BeginScript="" EndScript="" SQLQuery="SELECT (((c.city)::text || \a,\a::text) || (cy.country)::text) AS store, (((m.first_name)::text || \a \a::text) || (m.last_name)::text) AS manager, sum(p.amount) AS total_sales FROM (((((((payment p JOIN rental r ON ((p.rental_id = r.rental_id))) JOIN inventory i ON ((r.inventory_id = i.inventory_id))) JOIN store s ON ((i.store_id = s.store_id))) JOIN address a ON ((s.address_id = a.address_id))) JOIN city c ON ((a.city_id = c.city_id))) JOIN country cy ON ((c.country_id = cy.country_id))) JOIN staff m ON ((s.manager_staff_id = m.staff_id))) GROUP BY cy.country, c.city, s.store_id, m.first_name, m.last_name ORDER BY cy.country, c.city" Columns="store,manager,total_sales" Tables="\Apayment p\A,\Arental r\A,\Ainventory i\A,\Astore s\A,\Aaddress a\A,\Acity c\A,\Acountry cy\A,\Astaff m\A" Temporary="0" SecurityBarrier="0" Recursive="0" Materialized="0" NoData="0" TablespaceID="0" Generate="1" ACL="" >
</VIEW>

<VIEW ID="137311" Name="staff_list" SchemaOID="0" SchemaName="public" OwnerID="0" OwnerName="" XPos="40" YPos="1360" LineColor="8388608" BackColor="3329434" FontColor="0" Comments="" Description="" Annotation="" BeginScript="" EndScript="" SQLQuery="SELECT s.staff_id AS id, (((s.first_name)::text || \a \a::text) || (s.last_name)::text) AS name, a.address, a.postal_code AS \Azip code\A, a.phone, city.city, country.country, s.store_id AS sid FROM (((staff s JOIN address a ON ((s.address_id = a.address_id))) JOIN city ON ((a.city_id = city.city_id))) JOIN country ON ((city.country_id = country.country_id)))" Columns="id,name,a.address,\A\A\Azip code\A\A\A,a.phone,city.city,country.country,sid" Tables="\Astaff s\A,\Aaddress a\A,city,country" Temporary="0" SecurityBarrier="0" Recursive="0" Materialized="0" NoData="0" TablespaceID="0" Generate="1" ACL="" >
</VIEW>

</VIEWS>

</METADATA>
