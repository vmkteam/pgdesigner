        <column name="productid" references="productid"></column>
      </fk>
      <fk name="FK_SpecialOfferProduct_SpecialOffer_SpecialOfferID" to-table="specialoffer" on-delete="restrict" on-update="restrict">
        <column name="specialofferid" references="specialofferid"></column>
      </fk>
    </table>
    <table name="store" comment="Customers (resellers) of Adventure Works products.">
      <column name="businessentityid" type="integer" nullable="false" comment="Primary key. Foreign key to Customer.BusinessEntityID."></column>
      <column name="name" type="Name" nullable="false" comment="Name of the store."></column>
