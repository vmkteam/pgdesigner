		<COLUMN ID="114" Name="enddate" Pos="5" Datatype="1114" Type="timestamp" Width="-1" Prec="0" NotNull="0" AutoInc="0" Collation="" PrimaryKey="0" IsFKey="0" DefaultValue="" QuoteDefault="0" Comments="Date the component stopped being used in the assembly item."></COLUMN>
