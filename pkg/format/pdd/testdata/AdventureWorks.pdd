<NOTES>
<NOTE ID="94876" Name="Note_01" XPos="80" YPos="50" Text="-- All 68 tables are properly set up.\n-- All 20 views are established.\n-- 68 additional convenience views are added which:\n--   * Provide a shorthand to refer to tables.\n--   * Add an \Aid\A column to a primary key or primary-ish key if it makes sense.\n--\n--   For example, with the convenience views you can simply do:\n--       SELECT pe.p.firstname, hr.e.jobtitle\n--       FROM pe.p\n--         INNER JOIN hr.e ON pe.p.id = hr.e.id;\n--   Instead of:\n--       SELECT p.firstname, e.jobtitle\n--       FROM person.person AS p\n--         INNER JOIN humanresources.employee AS e ON p.businessentityid = e.businessentityid;\n" BackColor="15793151" LineColor="0" FontColor="0" />
</NOTES>

<STOREDPROCES>
</STOREDPROCES>

<VIEWS>
<VIEW ID="94465" Name="vadditionalcontactinfo" SchemaOID="92746" SchemaName="person" OwnerID="16393" OwnerName="pasha" XPos="1680" YPos="3220" LineColor="8388608" BackColor="12639424" FontColor="0" Comments="" Description="" Annotation="" BeginScript="" EndScript="" SQLQuery="SELECT p.businessentityid,\n    p.firstname,\n    p.middlename,\n    p.lastname,\n    (xpath(\a(act:telephoneNumber)[1]/act:number/text()\a::text, additional.node, \a{{act,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ContactTypes}}\a::text[]))[1] AS telephonenumber,\n    btrim((((xpath(\a(act:telephoneNumber)[1]/act:SpecialInstructions/text()\a::text, additional.node, \a{{act,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ContactTypes}}\a::text[]))[1])::character varying)::text) AS telephonespecialinstructions,\n    (xpath(\a(act:homePostalAddress)[1]/act:Street/text()\a::text, additional.node, \a{{act,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ContactTypes}}\a::text[]))[1] AS street,\n    (xpath(\a(act:homePostalAddress)[1]/act:City/text()\a::text, additional.node, \a{{act,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ContactTypes}}\a::text[]))[1] AS city,\n    (xpath(\a(act:homePostalAddress)[1]/act:StateProvince/text()\a::text, additional.node, \a{{act,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ContactTypes}}\a::text[]))[1] AS stateprovince,\n    (xpath(\a(act:homePostalAddress)[1]/act:PostalCode/text()\a::text, additional.node, \a{{act,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ContactTypes}}\a::text[]))[1] AS postalcode,\n    (xpath(\a(act:homePostalAddress)[1]/act:CountryRegion/text()\a::text, additional.node, \a{{act,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ContactTypes}}\a::text[]))[1] AS countryregion,\n    (xpath(\a(act:homePostalAddress)[1]/act:SpecialInstructions/text()\a::text, additional.node, \a{{act,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ContactTypes}}\a::text[]))[1] AS homeaddressspecialinstructions,\n    (xpath(\a(act:eMail)[1]/act:eMailAddress/text()\a::text, additional.node, \a{{act,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ContactTypes}}\a::text[]))[1] AS emailaddress,\n    btrim((((xpath(\a(act:eMail)[1]/act:SpecialInstructions/text()\a::text, additional.node, \a{{act,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ContactTypes}}\a::text[]))[1])::character varying)::text) AS emailspecialinstructions,\n    (xpath(\a((act:eMail)[1]/act:SpecialInstructions/act:telephoneNumber)[1]/act:number/text()\a::text, additional.node, \a{{act,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ContactTypes}}\a::text[]))[1] AS emailtelephonenumber,\n    p.rowguid,\n    p.modifieddate\n   FROM (person.person p\n     LEFT JOIN ( SELECT person.businessentityid,\n            unnest(xpath(\a/ci:AdditionalContactInfo\a::text, person.additionalcontactinfo, \a{{ci,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ContactInfo}}\a::text[])) AS node\n           FROM person.person\n          WHERE (person.additionalcontactinfo IS NOT NULL)) additional ON ((p.businessentityid = additional.businessentityid)))" Columns="p.businessentityid,p.firstname,p.middlename,p.lastname,telephonenumber,telephonespecialinstructions,street,city,stateprovince,postalcode,countryregion,homeaddressspecialinstructions,emailaddress,emailspecialinstructions,emailtelephonenumber,p.rowguid,p.modifieddate" Tables="\Aperson.person p\A,\A( SELECT person.businessentityid,\n            unnest(xpath(\a/ci...\A" Temporary="0" SecurityBarrier="0" Recursive="0" Materialized="0" NoData="0" TablespaceID="0" Generate="1" ACL="" >
</VIEW>

<VIEW ID="94550" Name="vstateprovincecountryregion" SchemaOID="92746" SchemaName="person" OwnerID="16393" OwnerName="pasha" XPos="5" YPos="3226" LineColor="8388608" BackColor="12639424" FontColor="0" Comments="" Description="" Annotation="" BeginScript="" EndScript="" SQLQuery="SELECT sp.stateprovinceid,\n    sp.stateprovincecode,\n    sp.isonlystateprovinceflag,\n    sp.name AS stateprovincename,\n    sp.territoryid,\n    cr.countryregioncode,\n    cr.name AS countryregionname\n   FROM (person.stateprovince sp\n     JOIN person.countryregion cr ON (((sp.countryregioncode)::text = (cr.countryregioncode)::text)))" Columns="sp.stateprovinceid,sp.stateprovincecode,sp.isonlystateprovinceflag,stateprovincename,sp.territoryid,cr.countryregioncode,countryregionname" Tables="\Aperson.stateprovince sp\A,\Aperson.countryregion cr\A" Temporary="0" SecurityBarrier="0" Recursive="0" Materialized="1" NoData="0" TablespaceID="0" Generate="1" ACL="" >
</VIEW>

<VIEW ID="94470" Name="vemployee" SchemaOID="92855" SchemaName="humanresources" OwnerID="16393" OwnerName="pasha" XPos="308" YPos="3226" LineColor="8388608" BackColor="12639424" FontColor="0" Comments="" Description="" Annotation="" BeginScript="" EndScript="" SQLQuery="SELECT e.businessentityid,\n    p.title,\n    p.firstname,\n    p.middlename,\n    p.lastname,\n    p.suffix,\n    e.jobtitle,\n    pp.phonenumber,\n    pnt.name AS phonenumbertype,\n    ea.emailaddress,\n    p.emailpromotion,\n    a.addressline1,\n    a.addressline2,\n    a.city,\n    sp.name AS stateprovincename,\n    a.postalcode,\n    cr.name AS countryregionname,\n    p.additionalcontactinfo\n   FROM ((((((((humanresources.employee e\n     JOIN person.person p ON ((p.businessentityid = e.businessentityid)))\n     JOIN person.businessentityaddress bea ON ((bea.businessentityid = e.businessentityid)))\n     JOIN person.address a ON ((a.addressid = bea.addressid)))\n     JOIN person.stateprovince sp ON ((sp.stateprovinceid = a.stateprovinceid)))\n     JOIN person.countryregion cr ON (((cr.countryregioncode)::text = (sp.countryregioncode)::text)))\n     LEFT JOIN person.personphone pp ON ((pp.businessentityid = p.businessentityid)))\n     LEFT JOIN person.phonenumbertype pnt ON ((pp.phonenumbertypeid = pnt.phonenumbertypeid)))\n     LEFT JOIN person.emailaddress ea ON ((p.businessentityid = ea.businessentityid)))" Columns="e.businessentityid,p.title,p.firstname,p.middlename,p.lastname,p.suffix,e.jobtitle,pp.phonenumber,phonenumbertype,ea.emailaddress,p.emailpromotion,a.addressline1,a.addressline2,a.city,stateprovincename,a.postalcode,countryregionname,p.additionalcontactinfo" Tables="\Ahumanresources.employee e\A,\Aperson.person p\A,\Aperson.businessentityaddress bea\A,\Aperson.address a\A,\Aperson.stateprovince sp\A,\Aperson.countryregion cr\A,\Aperson.personphone pp\A,\Aperson.phonenumbertype pnt\A,\Aperson.emailaddress ea\A" Temporary="0" SecurityBarrier="0" Recursive="0" Materialized="0" NoData="0" TablespaceID="0" Generate="1" ACL="" >
</VIEW>

<VIEW ID="94475" Name="vemployeedepartment" SchemaOID="92855" SchemaName="humanresources" OwnerID="16393" OwnerName="pasha" XPos="582" YPos="3226" LineColor="8388608" BackColor="12639424" FontColor="0" Comments="" Description="" Annotation="" BeginScript="" EndScript="" SQLQuery="SELECT e.businessentityid,\n    p.title,\n    p.firstname,\n    p.middlename,\n    p.lastname,\n    p.suffix,\n    e.jobtitle,\n    d.name AS department,\n    d.groupname,\n    edh.startdate\n   FROM (((humanresources.employee e\n     JOIN person.person p ON ((p.businessentityid = e.businessentityid)))\n     JOIN humanresources.employeedepartmenthistory edh ON ((e.businessentityid = edh.businessentityid)))\n     JOIN humanresources.department d ON ((edh.departmentid = d.departmentid)))\n  WHERE (edh.enddate IS NULL)" Columns="e.businessentityid,p.title,p.firstname,p.middlename,p.lastname,p.suffix,e.jobtitle,department,d.groupname,edh.startdate" Tables="\Ahumanresources.employee e\A,\Aperson.person p\A,\Ahumanresources.employeedepartmenthistory edh\A,\Ahumanresources.department d\A" Temporary="0" SecurityBarrier="0" Recursive="0" Materialized="0" NoData="0" TablespaceID="0" Generate="1" ACL="" >
</VIEW>

<VIEW ID="94480" Name="vemployeedepartmenthistory" SchemaOID="92855" SchemaName="humanresources" OwnerID="16393" OwnerName="pasha" XPos="860" YPos="3220" LineColor="8388608" BackColor="12639424" FontColor="0" Comments="" Description="" Annotation="" BeginScript="" EndScript="" SQLQuery="SELECT e.businessentityid,\n    p.title,\n    p.firstname,\n    p.middlename,\n    p.lastname,\n    p.suffix,\n    s.name AS shift,\n    d.name AS department,\n    d.groupname,\n    edh.startdate,\n    edh.enddate\n   FROM ((((humanresources.employee e\n     JOIN person.person p ON ((p.businessentityid = e.businessentityid)))\n     JOIN humanresources.employeedepartmenthistory edh ON ((e.businessentityid = edh.businessentityid)))\n     JOIN humanresources.department d ON ((edh.departmentid = d.departmentid)))\n     JOIN humanresources.shift s ON ((s.shiftid = edh.shiftid)))" Columns="e.businessentityid,p.title,p.firstname,p.middlename,p.lastname,p.suffix,shift,department,d.groupname,edh.startdate,edh.enddate" Tables="\Ahumanresources.employee e\A,\Aperson.person p\A,\Ahumanresources.employeedepartmenthistory edh\A,\Ahumanresources.department d\A,\Ahumanresources.shift s\A" Temporary="0" SecurityBarrier="0" Recursive="0" Materialized="0" NoData="0" TablespaceID="0" Generate="1" ACL="" >
</VIEW>

<VIEW ID="94495" Name="vjobcandidate" SchemaOID="92855" SchemaName="humanresources" OwnerID="16393" OwnerName="pasha" XPos="1160" YPos="3220" LineColor="8388608" BackColor="12639424" FontColor="0" Comments="" Description="" Annotation="" BeginScript="" EndScript="" SQLQuery="SELECT jobcandidate.jobcandidateid,\n    jobcandidate.businessentityid,\n    ((xpath(\a/n:Resume/n:Name/n:Name.Prefix/text()\a::text, jobcandidate.resume, \a{{n,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/Resume}}\a::text[]))[1])::character varying(30) AS \AName.Prefix\A,\n    ((xpath(\a/n:Resume/n:Name/n:Name.First/text()\a::text, jobcandidate.resume, \a{{n,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/Resume}}\a::text[]))[1])::character varying(30) AS \AName.First\A,\n    ((xpath(\a/n:Resume/n:Name/n:Name.Middle/text()\a::text, jobcandidate.resume, \a{{n,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/Resume}}\a::text[]))[1])::character varying(30) AS \AName.Middle\A,\n    ((xpath(\a/n:Resume/n:Name/n:Name.Last/text()\a::text, jobcandidate.resume, \a{{n,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/Resume}}\a::text[]))[1])::character varying(30) AS \AName.Last\A,\n    ((xpath(\a/n:Resume/n:Name/n:Name.Suffix/text()\a::text, jobcandidate.resume, \a{{n,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/Resume}}\a::text[]))[1])::character varying(30) AS \AName.Suffix\A,\n    ((xpath(\a/n:Resume/n:Skills/text()\a::text, jobcandidate.resume, \a{{n,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/Resume}}\a::text[]))[1])::character varying AS \ASkills\A,\n    ((xpath(\an:Address/n:Addr.Type/text()\a::text, jobcandidate.resume, \a{{n,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/Resume}}\a::text[]))[1])::character varying(30) AS \AAddr.Type\A,\n    ((xpath(\an:Address/n:Addr.Location/n:Location/n:Loc.CountryRegion/text()\a::text, jobcandidate.resume, \a{{n,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/Resume}}\a::text[]))[1])::character varying(100) AS \AAddr.Loc.CountryRegion\A,\n    ((xpath(\an:Address/n:Addr.Location/n:Location/n:Loc.State/text()\a::text, jobcandidate.resume, \a{{n,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/Resume}}\a::text[]))[1])::character varying(100) AS \AAddr.Loc.State\A,\n    ((xpath(\an:Address/n:Addr.Location/n:Location/n:Loc.City/text()\a::text, jobcandidate.resume, \a{{n,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/Resume}}\a::text[]))[1])::character varying(100) AS \AAddr.Loc.City\A,\n    ((xpath(\an:Address/n:Addr.PostalCode/text()\a::text, jobcandidate.resume, \a{{n,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/Resume}}\a::text[]))[1])::character varying(20) AS \AAddr.PostalCode\A,\n    ((xpath(\a/n:Resume/n:EMail/text()\a::text, jobcandidate.resume, \a{{n,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/Resume}}\a::text[]))[1])::character varying AS \AEMail\A,\n    ((xpath(\a/n:Resume/n:WebSite/text()\a::text, jobcandidate.resume, \a{{n,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/Resume}}\a::text[]))[1])::character varying AS \AWebSite\A,\n    jobcandidate.modifieddate\n   FROM humanresources.jobcandidate" Columns="jobcandidate.jobcandidateid,jobcandidate.businessentityid,\A\A\AName.Prefix\A\A\A,\A\A\AName.First\A\A\A,\A\A\AName.Middle\A\A\A,\A\A\AName.Last\A\A\A,\A\A\AName.Suffix\A\A\A,\A\A\ASkills\A\A\A,\A\A\AAddr.Type\A\A\A,\A\A\AAddr.Loc.CountryRegion\A\A\A,\A\A\AAddr.Loc.State\A\A\A,\A\A\AAddr.Loc.City\A\A\A,\A\A\AAddr.PostalCode\A\A\A,\A\A\AEMail\A\A\A,\A\A\AWebSite\A\A\A,jobcandidate.modifieddate" Tables="humanresources.jobcandidate" Temporary="0" SecurityBarrier="0" Recursive="0" Materialized="0" NoData="0" TablespaceID="0" Generate="1" ACL="" >
</VIEW>

<VIEW ID="94505" Name="vjobcandidateeducation" SchemaOID="92855" SchemaName="humanresources" OwnerID="16393" OwnerName="pasha" XPos="1410" YPos="3220" LineColor="8388608" BackColor="12639424" FontColor="0" Comments="" Description="" Annotation="" BeginScript="" EndScript="" SQLQuery="SELECT jc.jobcandidateid,\n    ((xpath(\a/root/ns:Education/ns:Edu.Level/text()\a::text, jc.doc, \a{{ns,http://adventureworks.com}}\a::text[]))[1])::character varying(50) AS \AEdu.Level\A,\n    (((xpath(\a/root/ns:Education/ns:Edu.StartDate/text()\a::text, jc.doc, \a{{ns,http://adventureworks.com}}\a::text[]))[1])::character varying(20))::date AS \AEdu.StartDate\A,\n    (((xpath(\a/root/ns:Education/ns:Edu.EndDate/text()\a::text, jc.doc, \a{{ns,http://adventureworks.com}}\a::text[]))[1])::character varying(20))::date AS \AEdu.EndDate\A,\n    ((xpath(\a/root/ns:Education/ns:Edu.Degree/text()\a::text, jc.doc, \a{{ns,http://adventureworks.com}}\a::text[]))[1])::character varying(50) AS \AEdu.Degree\A,\n    ((xpath(\a/root/ns:Education/ns:Edu.Major/text()\a::text, jc.doc, \a{{ns,http://adventureworks.com}}\a::text[]))[1])::character varying(50) AS \AEdu.Major\A,\n    ((xpath(\a/root/ns:Education/ns:Edu.Minor/text()\a::text, jc.doc, \a{{ns,http://adventureworks.com}}\a::text[]))[1])::character varying(50) AS \AEdu.Minor\A,\n    ((xpath(\a/root/ns:Education/ns:Edu.GPA/text()\a::text, jc.doc, \a{{ns,http://adventureworks.com}}\a::text[]))[1])::character varying(5) AS \AEdu.GPA\A,\n    ((xpath(\a/root/ns:Education/ns:Edu.GPAScale/text()\a::text, jc.doc, \a{{ns,http://adventureworks.com}}\a::text[]))[1])::character varying(5) AS \AEdu.GPAScale\A,\n    ((xpath(\a/root/ns:Education/ns:Edu.School/text()\a::text, jc.doc, \a{{ns,http://adventureworks.com}}\a::text[]))[1])::character varying(100) AS \AEdu.School\A,\n    ((xpath(\a/root/ns:Education/ns:Edu.Location/ns:Location/ns:Loc.CountryRegion/text()\a::text, jc.doc, \a{{ns,http://adventureworks.com}}\a::text[]))[1])::character varying(100) AS \AEdu.Loc.CountryRegion\A,\n    ((xpath(\a/root/ns:Education/ns:Edu.Location/ns:Location/ns:Loc.State/text()\a::text, jc.doc, \a{{ns,http://adventureworks.com}}\a::text[]))[1])::character varying(100) AS \AEdu.Loc.State\A,\n    ((xpath(\a/root/ns:Education/ns:Edu.Location/ns:Location/ns:Loc.City/text()\a::text, jc.doc, \a{{ns,http://adventureworks.com}}\a::text[]))[1])::character varying(100) AS \AEdu.Loc.City\A\n   FROM ( SELECT unnesting.jobcandidateid,\n            (((\a\kroot xmlns:ns=\Ahttp://adventureworks.com\A\g\a::text || ((unnesting.education)::character varying)::text) || \a\k/root\g\a::text))::xml AS doc\n           FROM ( SELECT jobcandidate.jobcandidateid,\n                    unnest(xpath(\a/ns:Resume/ns:Education\a::text, jobcandidate.resume, \a{{ns,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/Resume}}\a::text[])) AS education\n                   FROM humanresources.jobcandidate) unnesting) jc" Columns="jc.jobcandidateid,\A\A\AEdu.Level\A\A\A,\A\A\AEdu.StartDate\A\A\A,\A\A\AEdu.EndDate\A\A\A,\A\A\AEdu.Degree\A\A\A,\A\A\AEdu.Major\A\A\A,\A\A\AEdu.Minor\A\A\A,\A\A\AEdu.GPA\A\A\A,\A\A\AEdu.GPAScale\A\A\A,\A\A\AEdu.School\A\A\A,\A\A\AEdu.Loc.CountryRegion\A\A\A,\A\A\AEdu.Loc.State\A\A\A,\A\A\AEdu.Loc.City\A\A\A" Tables="\A( SELECT unnesting.jobcandidateid,\n            (((\a\kroot xmlns:...\A" Temporary="0" SecurityBarrier="0" Recursive="0" Materialized="0" NoData="0" TablespaceID="0" Generate="1" ACL="" >
</VIEW>

<VIEW ID="94500" Name="vjobcandidateemployment" SchemaOID="92855" SchemaName="humanresources" OwnerID="16393" OwnerName="pasha" XPos="1940" YPos="3220" LineColor="8388608" BackColor="12639424" FontColor="0" Comments="" Description="" Annotation="" BeginScript="" EndScript="" SQLQuery="SELECT jobcandidate.jobcandidateid,\n    ((unnest(xpath(\a/ns:Resume/ns:Employment/ns:Emp.StartDate/text()\a::text, jobcandidate.resume, \a{{ns,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/Resume}}\a::text[])))::character varying(20))::date AS \AEmp.StartDate\A,\n    ((unnest(xpath(\a/ns:Resume/ns:Employment/ns:Emp.EndDate/text()\a::text, jobcandidate.resume, \a{{ns,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/Resume}}\a::text[])))::character varying(20))::date AS \AEmp.EndDate\A,\n    (unnest(xpath(\a/ns:Resume/ns:Employment/ns:Emp.OrgName/text()\a::text, jobcandidate.resume, \a{{ns,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/Resume}}\a::text[])))::character varying(100) AS \AEmp.OrgName\A,\n    (unnest(xpath(\a/ns:Resume/ns:Employment/ns:Emp.JobTitle/text()\a::text, jobcandidate.resume, \a{{ns,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/Resume}}\a::text[])))::character varying(100) AS \AEmp.JobTitle\A,\n    (unnest(xpath(\a/ns:Resume/ns:Employment/ns:Emp.Responsibility/text()\a::text, jobcandidate.resume, \a{{ns,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/Resume}}\a::text[])))::character varying AS \AEmp.Responsibility\A,\n    (unnest(xpath(\a/ns:Resume/ns:Employment/ns:Emp.FunctionCategory/text()\a::text, jobcandidate.resume, \a{{ns,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/Resume}}\a::text[])))::character varying AS \AEmp.FunctionCategory\A,\n    (unnest(xpath(\a/ns:Resume/ns:Employment/ns:Emp.IndustryCategory/text()\a::text, jobcandidate.resume, \a{{ns,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/Resume}}\a::text[])))::character varying AS \AEmp.IndustryCategory\A,\n    (unnest(xpath(\a/ns:Resume/ns:Employment/ns:Emp.Location/ns:Location/ns:Loc.CountryRegion/text()\a::text, jobcandidate.resume, \a{{ns,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/Resume}}\a::text[])))::character varying AS \AEmp.Loc.CountryRegion\A,\n    (unnest(xpath(\a/ns:Resume/ns:Employment/ns:Emp.Location/ns:Location/ns:Loc.State/text()\a::text, jobcandidate.resume, \a{{ns,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/Resume}}\a::text[])))::character varying AS \AEmp.Loc.State\A,\n    (unnest(xpath(\a/ns:Resume/ns:Employment/ns:Emp.Location/ns:Location/ns:Loc.City/text()\a::text, jobcandidate.resume, \a{{ns,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/Resume}}\a::text[])))::character varying AS \AEmp.Loc.City\A\n   FROM humanresources.jobcandidate" Columns="jobcandidate.jobcandidateid,\A\A\AEmp.StartDate\A\A\A,\A\A\AEmp.EndDate\A\A\A,\A\A\AEmp.OrgName\A\A\A,\A\A\AEmp.JobTitle\A\A\A,\A\A\AEmp.Responsibility\A\A\A,\A\A\AEmp.FunctionCategory\A\A\A,\A\A\AEmp.IndustryCategory\A\A\A,\A\A\AEmp.Loc.CountryRegion\A\A\A,\A\A\AEmp.Loc.State\A\A\A,\A\A\AEmp.Loc.City\A\A\A" Tables="humanresources.jobcandidate" Temporary="0" SecurityBarrier="0" Recursive="0" Materialized="0" NoData="0" TablespaceID="0" Generate="1" ACL="" >
</VIEW>

<VIEW ID="94510" Name="vproductanddescription" SchemaOID="92926" SchemaName="production" OwnerID="16393" OwnerName="pasha" XPos="2202" YPos="3226" LineColor="8388608" BackColor="12639424" FontColor="0" Comments="" Description="" Annotation="" BeginScript="" EndScript="" SQLQuery="SELECT p.productid,\n    p.name,\n    pm.name AS productmodel,\n    pmx.cultureid,\n    pd.description\n   FROM (((production.product p\n     JOIN production.productmodel pm ON ((p.productmodelid = pm.productmodelid)))\n     JOIN production.productmodelproductdescriptionculture pmx ON ((pm.productmodelid = pmx.productmodelid)))\n     JOIN production.productdescription pd ON ((pmx.productdescriptionid = pd.productdescriptionid)))" Columns="p.productid,p.name,productmodel,pmx.cultureid,pd.description" Tables="\Aproduction.product p\A,\Aproduction.productmodel pm\A,\Aproduction.productmodelproductdescriptionculture pmx\A,\Aproduction.productdescription pd\A" Temporary="0" SecurityBarrier="0" Recursive="0" Materialized="1" NoData="0" TablespaceID="0" Generate="1" ACL="" >
</VIEW>

<VIEW ID="94526" Name="vproductmodelcatalogdescription" SchemaOID="92926" SchemaName="production" OwnerID="16393" OwnerName="pasha" XPos="2720" YPos="3220" LineColor="8388608" BackColor="12639424" FontColor="0" Comments="" Description="" Annotation="" BeginScript="" EndScript="" SQLQuery="SELECT productmodel.productmodelid,\n    productmodel.name,\n    ((xpath(\a/p1:ProductDescription/p1:Summary/html:p/text()\a::text, productmodel.catalogdescription, \a{{p1,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ProductModelDescription},{html,http://www.w3.org/1999/xhtml}}\a::text[]))[1])::character varying AS \ASummary\A,\n    ((xpath(\a/p1:ProductDescription/p1:Manufacturer/p1:Name/text()\a::text, productmodel.catalogdescription, \a{{p1,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ProductModelDescription}}\a::text[]))[1])::character varying AS manufacturer,\n    ((xpath(\a/p1:ProductDescription/p1:Manufacturer/p1:Copyright/text()\a::text, productmodel.catalogdescription, \a{{p1,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ProductModelDescription}}\a::text[]))[1])::character varying(30) AS copyright,\n    ((xpath(\a/p1:ProductDescription/p1:Manufacturer/p1:ProductURL/text()\a::text, productmodel.catalogdescription, \a{{p1,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ProductModelDescription}}\a::text[]))[1])::character varying(256) AS producturl,\n    ((xpath(\a/p1:ProductDescription/p1:Features/wm:Warranty/wm:WarrantyPeriod/text()\a::text, productmodel.catalogdescription, \a{{p1,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ProductModelDescription},{wm,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ProductModelWarrAndMain}}\a::text[]))[1])::character varying(256) AS warrantyperiod,\n    ((xpath(\a/p1:ProductDescription/p1:Features/wm:Warranty/wm:Description/text()\a::text, productmodel.catalogdescription, \a{{p1,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ProductModelDescription},{wm,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ProductModelWarrAndMain}}\a::text[]))[1])::character varying(256) AS warrantydescription,\n    ((xpath(\a/p1:ProductDescription/p1:Features/wm:Maintenance/wm:NoOfYears/text()\a::text, productmodel.catalogdescription, \a{{p1,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ProductModelDescription},{wm,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ProductModelWarrAndMain}}\a::text[]))[1])::character varying(256) AS noofyears,\n    ((xpath(\a/p1:ProductDescription/p1:Features/wm:Maintenance/wm:Description/text()\a::text, productmodel.catalogdescription, \a{{p1,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ProductModelDescription},{wm,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ProductModelWarrAndMain}}\a::text[]))[1])::character varying(256) AS maintenancedescription,\n    ((xpath(\a/p1:ProductDescription/p1:Features/wf:wheel/text()\a::text, productmodel.catalogdescription, \a{{p1,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ProductModelDescription},{wf,http://www.adventure-works.com/schemas/OtherFeatures}}\a::text[]))[1])::character varying(256) AS wheel,\n    ((xpath(\a/p1:ProductDescription/p1:Features/wf:saddle/text()\a::text, productmodel.catalogdescription, \a{{p1,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ProductModelDescription},{wf,http://www.adventure-works.com/schemas/OtherFeatures}}\a::text[]))[1])::character varying(256) AS saddle,\n    ((xpath(\a/p1:ProductDescription/p1:Features/wf:pedal/text()\a::text, productmodel.catalogdescription, \a{{p1,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ProductModelDescription},{wf,http://www.adventure-works.com/schemas/OtherFeatures}}\a::text[]))[1])::character varying(256) AS pedal,\n    ((xpath(\a/p1:ProductDescription/p1:Features/wf:BikeFrame/text()\a::text, productmodel.catalogdescription, \a{{p1,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ProductModelDescription},{wf,http://www.adventure-works.com/schemas/OtherFeatures}}\a::text[]))[1])::character varying AS bikeframe,\n    ((xpath(\a/p1:ProductDescription/p1:Features/wf:crankset/text()\a::text, productmodel.catalogdescription, \a{{p1,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ProductModelDescription},{wf,http://www.adventure-works.com/schemas/OtherFeatures}}\a::text[]))[1])::character varying(256) AS crankset,\n    ((xpath(\a/p1:ProductDescription/p1:Picture/p1:Angle/text()\a::text, productmodel.catalogdescription, \a{{p1,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ProductModelDescription}}\a::text[]))[1])::character varying(256) AS pictureangle,\n    ((xpath(\a/p1:ProductDescription/p1:Picture/p1:Size/text()\a::text, productmodel.catalogdescription, \a{{p1,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ProductModelDescription}}\a::text[]))[1])::character varying(256) AS picturesize,\n    ((xpath(\a/p1:ProductDescription/p1:Picture/p1:ProductPhotoID/text()\a::text, productmodel.catalogdescription, \a{{p1,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ProductModelDescription}}\a::text[]))[1])::character varying(256) AS productphotoid,\n    ((xpath(\a/p1:ProductDescription/p1:Specifications/Material/text()\a::text, productmodel.catalogdescription, \a{{p1,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ProductModelDescription}}\a::text[]))[1])::character varying(256) AS material,\n    ((xpath(\a/p1:ProductDescription/p1:Specifications/Color/text()\a::text, productmodel.catalogdescription, \a{{p1,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ProductModelDescription}}\a::text[]))[1])::character varying(256) AS color,\n    ((xpath(\a/p1:ProductDescription/p1:Specifications/ProductLine/text()\a::text, productmodel.catalogdescription, \a{{p1,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ProductModelDescription}}\a::text[]))[1])::character varying(256) AS productline,\n    ((xpath(\a/p1:ProductDescription/p1:Specifications/Style/text()\a::text, productmodel.catalogdescription, \a{{p1,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ProductModelDescription}}\a::text[]))[1])::character varying(256) AS style,\n    ((xpath(\a/p1:ProductDescription/p1:Specifications/RiderExperience/text()\a::text, productmodel.catalogdescription, \a{{p1,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ProductModelDescription}}\a::text[]))[1])::character varying(1024) AS riderexperience,\n    productmodel.rowguid,\n    productmodel.modifieddate\n   FROM production.productmodel\n  WHERE (productmodel.catalogdescription IS NOT NULL)" Columns="productmodel.productmodelid,productmodel.name,\A\A\ASummary\A\A\A,manufacturer,copyright,producturl,warrantyperiod,warrantydescription,noofyears,maintenancedescription,wheel,saddle,pedal,bikeframe,crankset,pictureangle,picturesize,productphotoid,material,color,productline,style,riderexperience,productmodel.rowguid,productmodel.modifieddate" Tables="production.productmodel" Temporary="0" SecurityBarrier="0" Recursive="0" Materialized="0" NoData="0" TablespaceID="0" Generate="1" ACL="" >
</VIEW>

<VIEW ID="94531" Name="vproductmodelinstructions" SchemaOID="92926" SchemaName="production" OwnerID="16393" OwnerName="pasha" XPos="2460" YPos="3230" LineColor="8388608" BackColor="12639424" FontColor="0" Comments="" Description="" Annotation="" BeginScript="" EndScript="" SQLQuery="SELECT pm.productmodelid,\n    pm.name,\n    ((xpath(\a/ns:root/text()\a::text, pm.instructions, \a{{ns,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ProductModelManuInstructions}}\a::text[]))[1])::character varying AS instructions,\n    (((xpath(\a@LocationID\a::text, pm.mfginstructions))[1])::character varying)::integer AS \ALocationID\A,\n    (((xpath(\a@SetupHours\a::text, pm.mfginstructions))[1])::character varying)::numeric(9,4) AS \ASetupHours\A,\n    (((xpath(\a@MachineHours\a::text, pm.mfginstructions))[1])::character varying)::numeric(9,4) AS \AMachineHours\A,\n    (((xpath(\a@LaborHours\a::text, pm.mfginstructions))[1])::character varying)::numeric(9,4) AS \ALaborHours\A,\n    (((xpath(\a@LotSize\a::text, pm.mfginstructions))[1])::character varying)::integer AS \ALotSize\A,\n    ((xpath(\a/step/text()\a::text, pm.step))[1])::character varying(1024) AS \AStep\A,\n    pm.rowguid,\n    pm.modifieddate\n   FROM ( SELECT locations.productmodelid,\n            locations.name,\n            locations.rowguid,\n            locations.modifieddate,\n            locations.instructions,\n            locations.mfginstructions,\n            unnest(xpath(\astep\a::text, locations.mfginstructions)) AS step\n           FROM ( SELECT productmodel.productmodelid,\n                    productmodel.name,\n                    productmodel.rowguid,\n                    productmodel.modifieddate,\n                    productmodel.instructions,\n                    unnest(xpath(\a/ns:root/ns:Location\a::text, productmodel.instructions, \a{{ns,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ProductModelManuInstructions}}\a::text[])) AS mfginstructions\n                   FROM production.productmodel) locations) pm" Columns="pm.productmodelid,pm.name,instructions,\A\A\ALocationID\A\A\A,\A\A\ASetupHours\A\A\A,\A\A\AMachineHours\A\A\A,\A\A\ALaborHours\A\A\A,\A\A\ALotSize\A\A\A,\A\A\AStep\A\A\A,pm.rowguid,pm.modifieddate" Tables="\A( SELECT locations.productmodelid,\n            locations.name,...\A" Temporary="0" SecurityBarrier="0" Recursive="0" Materialized="0" NoData="0" TablespaceID="0" Generate="1" ACL="" >
</VIEW>

<VIEW ID="94585" Name="vvendorwithaddresses" SchemaOID="93201" SchemaName="purchasing" OwnerID="16393" OwnerName="pasha" XPos="5" YPos="3790" LineColor="8388608" BackColor="12639424" FontColor="0" Comments="" Description="" Annotation="" BeginScript="" EndScript="" SQLQuery="SELECT v.businessentityid,\n    v.name,\n    at.name AS addresstype,\n    a.addressline1,\n    a.addressline2,\n    a.city,\n    sp.name AS stateprovincename,\n    a.postalcode,\n    cr.name AS countryregionname\n   FROM (((((purchasing.vendor v\n     JOIN person.businessentityaddress bea ON ((bea.businessentityid = v.businessentityid)))\n     JOIN person.address a ON ((a.addressid = bea.addressid)))\n     JOIN person.stateprovince sp ON ((sp.stateprovinceid = a.stateprovinceid)))\n     JOIN person.countryregion cr ON (((cr.countryregioncode)::text = (sp.countryregioncode)::text)))\n     JOIN person.addresstype at ON ((at.addresstypeid = bea.addresstypeid)))" Columns="v.businessentityid,v.name,addresstype,a.addressline1,a.addressline2,a.city,stateprovincename,a.postalcode,countryregionname" Tables="\Apurchasing.vendor v\A,\Aperson.businessentityaddress bea\A,\Aperson.address a\A,\Aperson.stateprovince sp\A,\Aperson.countryregion cr\A,\Aperson.addresstype at\A" Temporary="0" SecurityBarrier="0" Recursive="0" Materialized="0" NoData="0" TablespaceID="0" Generate="1" ACL="" >
</VIEW>

<VIEW ID="94580" Name="vvendorwithcontacts" SchemaOID="93201" SchemaName="purchasing" OwnerID="16393" OwnerName="pasha" XPos="301" YPos="3790" LineColor="8388608" BackColor="12639424" FontColor="0" Comments="" Description="" Annotation="" BeginScript="" EndScript="" SQLQuery="SELECT v.businessentityid,\n    v.name,\n    ct.name AS contacttype,\n    p.title,\n    p.firstname,\n    p.middlename,\n    p.lastname,\n    p.suffix,\n    pp.phonenumber,\n    pnt.name AS phonenumbertype,\n    ea.emailaddress,\n    p.emailpromotion\n   FROM ((((((purchasing.vendor v\n     JOIN person.businessentitycontact bec ON ((bec.businessentityid = v.businessentityid)))\n     JOIN person.contacttype ct ON ((ct.contacttypeid = bec.contacttypeid)))\n     JOIN person.person p ON ((p.businessentityid = bec.personid)))\n     LEFT JOIN person.emailaddress ea ON ((ea.businessentityid = p.businessentityid)))\n     LEFT JOIN person.personphone pp ON ((pp.businessentityid = p.businessentityid)))\n     LEFT JOIN person.phonenumbertype pnt ON ((pnt.phonenumbertypeid = pp.phonenumbertypeid)))" Columns="v.businessentityid,v.name,contacttype,p.title,p.firstname,p.middlename,p.lastname,p.suffix,pp.phonenumber,phonenumbertype,ea.emailaddress,p.emailpromotion" Tables="\Apurchasing.vendor v\A,\Aperson.businessentitycontact bec\A,\Aperson.contacttype ct\A,\Aperson.person p\A,\Aperson.emailaddress ea\A,\Aperson.personphone pp\A,\Aperson.phonenumbertype pnt\A" Temporary="0" SecurityBarrier="0" Recursive="0" Materialized="0" NoData="0" TablespaceID="0" Generate="1" ACL="" >
</VIEW>

<VIEW ID="94485" Name="vindividualcustomer" SchemaOID="93275" SchemaName="sales" OwnerID="16393" OwnerName="pasha" XPos="590" YPos="3790" LineColor="8388608" BackColor="12639424" FontColor="0" Comments="" Description="" Annotation="" BeginScript="" EndScript="" SQLQuery="SELECT p.businessentityid,\n    p.title,\n    p.firstname,\n    p.middlename,\n    p.lastname,\n    p.suffix,\n    pp.phonenumber,\n    pnt.name AS phonenumbertype,\n    ea.emailaddress,\n    p.emailpromotion,\n    at.name AS addresstype,\n    a.addressline1,\n    a.addressline2,\n    a.city,\n    sp.name AS stateprovincename,\n    a.postalcode,\n    cr.name AS countryregionname,\n    p.demographics\n   FROM (((((((((person.person p\n     JOIN person.businessentityaddress bea ON ((bea.businessentityid = p.businessentityid)))\n     JOIN person.address a ON ((a.addressid = bea.addressid)))\n     JOIN person.stateprovince sp ON ((sp.stateprovinceid = a.stateprovinceid)))\n     JOIN person.countryregion cr ON (((cr.countryregioncode)::text = (sp.countryregioncode)::text)))\n     JOIN person.addresstype at ON ((at.addresstypeid = bea.addresstypeid)))\n     JOIN sales.customer c ON ((c.personid = p.businessentityid)))\n     LEFT JOIN person.emailaddress ea ON ((ea.businessentityid = p.businessentityid)))\n     LEFT JOIN person.personphone pp ON ((pp.businessentityid = p.businessentityid)))\n     LEFT JOIN person.phonenumbertype pnt ON ((pnt.phonenumbertypeid = pp.phonenumbertypeid)))\n  WHERE (c.storeid IS NULL)" Columns="p.businessentityid,p.title,p.firstname,p.middlename,p.lastname,p.suffix,pp.phonenumber,phonenumbertype,ea.emailaddress,p.emailpromotion,addresstype,a.addressline1,a.addressline2,a.city,stateprovincename,a.postalcode,countryregionname,p.demographics" Tables="\Aperson.person p\A,\Aperson.businessentityaddress bea\A,\Aperson.address a\A,\Aperson.stateprovince sp\A,\Aperson.countryregion cr\A,\Aperson.addresstype at\A,\Asales.customer c\A,\Aperson.emailaddress ea\A,\Aperson.personphone pp\A,\Aperson.phonenumbertype pnt\A" Temporary="0" SecurityBarrier="0" Recursive="0" Materialized="0" NoData="0" TablespaceID="0" Generate="1" ACL="" >
</VIEW>

<VIEW ID="94490" Name="vpersondemographics" SchemaOID="93275" SchemaName="sales" OwnerID="16393" OwnerName="pasha" XPos="853" YPos="3790" LineColor="8388608" BackColor="12639424" FontColor="0" Comments="" Description="" Annotation="" BeginScript="" EndScript="" SQLQuery="SELECT person.businessentityid,\n    (((xpath(\an:TotalPurchaseYTD/text()\a::text, person.demographics, \a{{n,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/IndividualSurvey}}\a::text[]))[1])::character varying)::money AS totalpurchaseytd,\n    (((xpath(\an:DateFirstPurchase/text()\a::text, person.demographics, \a{{n,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/IndividualSurvey}}\a::text[]))[1])::character varying)::date AS datefirstpurchase,\n    (((xpath(\an:BirthDate/text()\a::text, person.demographics, \a{{n,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/IndividualSurvey}}\a::text[]))[1])::character varying)::date AS birthdate,\n    ((xpath(\an:MaritalStatus/text()\a::text, person.demographics, \a{{n,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/IndividualSurvey}}\a::text[]))[1])::character varying(1) AS maritalstatus,\n    ((xpath(\an:YearlyIncome/text()\a::text, person.demographics, \a{{n,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/IndividualSurvey}}\a::text[]))[1])::character varying(30) AS yearlyincome,\n    ((xpath(\an:Gender/text()\a::text, person.demographics, \a{{n,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/IndividualSurvey}}\a::text[]))[1])::character varying(1) AS gender,\n    (((xpath(\an:TotalChildren/text()\a::text, person.demographics, \a{{n,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/IndividualSurvey}}\a::text[]))[1])::character varying)::integer AS totalchildren,\n    (((xpath(\an:NumberChildrenAtHome/text()\a::text, person.demographics, \a{{n,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/IndividualSurvey}}\a::text[]))[1])::character varying)::integer AS numberchildrenathome,\n    ((xpath(\an:Education/text()\a::text, person.demographics, \a{{n,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/IndividualSurvey}}\a::text[]))[1])::character varying(30) AS education,\n    ((xpath(\an:Occupation/text()\a::text, person.demographics, \a{{n,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/IndividualSurvey}}\a::text[]))[1])::character varying(30) AS occupation,\n    (((xpath(\an:HomeOwnerFlag/text()\a::text, person.demographics, \a{{n,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/IndividualSurvey}}\a::text[]))[1])::character varying)::boolean AS homeownerflag,\n    (((xpath(\an:NumberCarsOwned/text()\a::text, person.demographics, \a{{n,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/IndividualSurvey}}\a::text[]))[1])::character varying)::integer AS numbercarsowned\n   FROM person.person\n  WHERE (person.demographics IS NOT NULL)" Columns="person.businessentityid,totalpurchaseytd,datefirstpurchase,birthdate,maritalstatus,yearlyincome,gender,totalchildren,numberchildrenathome,education,occupation,homeownerflag,numbercarsowned" Tables="person.person" Temporary="0" SecurityBarrier="0" Recursive="0" Materialized="0" NoData="0" TablespaceID="0" Generate="1" ACL="" >
</VIEW>

<VIEW ID="94536" Name="vsalesperson" SchemaOID="93275" SchemaName="sales" OwnerID="16393" OwnerName="pasha" XPos="1125" YPos="3790" LineColor="8388608" BackColor="12639424" FontColor="0" Comments="" Description="" Annotation="" BeginScript="" EndScript="" SQLQuery="SELECT s.businessentityid,\n    p.title,\n    p.firstname,\n    p.middlename,\n    p.lastname,\n    p.suffix,\n    e.jobtitle,\n    pp.phonenumber,\n    pnt.name AS phonenumbertype,\n    ea.emailaddress,\n    p.emailpromotion,\n    a.addressline1,\n    a.addressline2,\n    a.city,\n    sp.name AS stateprovincename,\n    a.postalcode,\n    cr.name AS countryregionname,\n    st.name AS territoryname,\n    st.\Agroup\A AS territorygroup,\n    s.salesquota,\n    s.salesytd,\n    s.saleslastyear\n   FROM ((((((((((sales.salesperson s\n     JOIN humanresources.employee e ON ((e.businessentityid = s.businessentityid)))\n     JOIN person.person p ON ((p.businessentityid = s.businessentityid)))\n     JOIN person.businessentityaddress bea ON ((bea.businessentityid = s.businessentityid)))\n     JOIN person.address a ON ((a.addressid = bea.addressid)))\n     JOIN person.stateprovince sp ON ((sp.stateprovinceid = a.stateprovinceid)))\n     JOIN person.countryregion cr ON (((cr.countryregioncode)::text = (sp.countryregioncode)::text)))\n     LEFT JOIN sales.salesterritory st ON ((st.territoryid = s.territoryid)))\n     LEFT JOIN person.emailaddress ea ON ((ea.businessentityid = p.businessentityid)))\n     LEFT JOIN person.personphone pp ON ((pp.businessentityid = p.businessentityid)))\n     LEFT JOIN person.phonenumbertype pnt ON ((pnt.phonenumbertypeid = pp.phonenumbertypeid)))" Columns="s.businessentityid,p.title,p.firstname,p.middlename,p.lastname,p.suffix,e.jobtitle,pp.phonenumber,phonenumbertype,ea.emailaddress,p.emailpromotion,a.addressline1,a.addressline2,a.city,stateprovincename,a.postalcode,countryregionname,territoryname,territorygroup,s.salesquota,s.salesytd,s.saleslastyear" Tables="\Asales.salesperson s\A,\Ahumanresources.employee e\A,\Aperson.person p\A,\Aperson.businessentityaddress bea\A,\Aperson.address a\A,\Aperson.stateprovince sp\A,\Aperson.countryregion cr\A,\Asales.salesterritory st\A,\Aperson.emailaddress ea\A,\Aperson.personphone pp\A,\Aperson.phonenumbertype pnt\A" Temporary="0" SecurityBarrier="0" Recursive="0" Materialized="0" NoData="0" TablespaceID="0" Generate="1" ACL="" >
</VIEW>

<VIEW ID="94546" Name="vsalespersonsalesbyfiscalyears" SchemaOID="93275" SchemaName="sales" OwnerID="16393" OwnerName="pasha" XPos="1361" YPos="3790" LineColor="8388608" BackColor="12639424" FontColor="0" Comments="" Description="" Annotation="" BeginScript="" EndScript="" SQLQuery="SELECT salestotal.\ASalesPersonID\A,\n    salestotal.\AFullName\A,\n    salestotal.\AJobTitle\A,\n    salestotal.\ASalesTerritory\A,\n    salestotal.\A2012\A,\n    salestotal.\A2013\A,\n    salestotal.\A2014\A\n   FROM crosstab(\aSELECT\n    SalesPersonID\n    ,FullName\n    ,JobTitle\n    ,SalesTerritory\n    ,FiscalYear\n    ,SalesTotal\nFROM Sales.vSalesPersonSalesByFiscalYearsData\nORDER BY 2,4\a::text, \aSELECT unnest(\a\a{2012,2013,2014}\a\a::text[])\a::text) salestotal(\ASalesPersonID\A integer, \AFullName\A text, \AJobTitle\A text, \ASalesTerritory\A text, \A2012\A numeric(12,4), \A2013\A numeric(12,4), \A2014\A numeric(12,4))" Columns="\Asalestotal.\A\ASalesPersonID\A\A\A,\Asalestotal.\A\AFullName\A\A\A,\Asalestotal.\A\AJobTitle\A\A\A,\Asalestotal.\A\ASalesTerritory\A\A\A,\Asalestotal.\A\A2012\A\A\A,\Asalestotal.\A\A2013\A\A\A,\Asalestotal.\A\A2014\A\A\A" Tables="\Acrosstab(\aSELECT\n    SalesPersonID\n    ,FullName\n    ,JobTitl...\A" Temporary="0" SecurityBarrier="0" Recursive="0" Materialized="0" NoData="0" TablespaceID="0" Generate="1" ACL="" >
</VIEW>

<VIEW ID="94541" Name="vsalespersonsalesbyfiscalyearsdata" SchemaOID="93275" SchemaName="sales" OwnerID="16393" OwnerName="pasha" XPos="1696" YPos="3790" LineColor="8388608" BackColor="12639424" FontColor="0" Comments="" Description="" Annotation="" BeginScript="" EndScript="" SQLQuery="SELECT granular.salespersonid,\n    granular.fullname,\n    granular.jobtitle,\n    granular.salesterritory,\n    sum(granular.subtotal) AS salestotal,\n    granular.fiscalyear\n   FROM ( SELECT soh.salespersonid,\n            ((((p.firstname)::text || \a \a::text) || COALESCE(((p.middlename)::text || \a \a::text), \a\a::text)) || (p.lastname)::text) AS fullname,\n            e.jobtitle,\n            st.name AS salesterritory,\n            soh.subtotal,\n            date_part(\ayear\a::text, (soh.orderdate + \a6 mons\a::interval)) AS fiscalyear\n           FROM ((((sales.salesperson sp\n             JOIN sales.salesorderheader soh ON ((sp.businessentityid = soh.salespersonid)))\n             JOIN sales.salesterritory st ON ((sp.territoryid = st.territoryid)))\n             JOIN humanresources.employee e ON ((soh.salespersonid = e.businessentityid)))\n             JOIN person.person p ON ((p.businessentityid = sp.businessentityid)))) granular\n  GROUP BY granular.salespersonid, granular.fullname, granular.jobtitle, granular.salesterritory, granular.fiscalyear" Columns="granular.salespersonid,granular.fullname,granular.jobtitle,granular.salesterritory,salestotal,granular.fiscalyear" Tables="\A( SELECT soh.salespersonid,\n            ((((p.firstname)::text ...\A" Temporary="0" SecurityBarrier="0" Recursive="0" Materialized="0" NoData="0" TablespaceID="0" Generate="1" ACL="" >
</VIEW>

<VIEW ID="94575" Name="vstorewithaddresses" SchemaOID="93275" SchemaName="sales" OwnerID="16393" OwnerName="pasha" XPos="2020" YPos="3790" LineColor="8388608" BackColor="12639424" FontColor="0" Comments="" Description="" Annotation="" BeginScript="" EndScript="" SQLQuery="SELECT s.businessentityid,\n    s.name,\n    at.name AS addresstype,\n    a.addressline1,\n    a.addressline2,\n    a.city,\n    sp.name AS stateprovincename,\n    a.postalcode,\n    cr.name AS countryregionname\n   FROM (((((sales.store s\n     JOIN person.businessentityaddress bea ON ((bea.businessentityid = s.businessentityid)))\n     JOIN person.address a ON ((a.addressid = bea.addressid)))\n     JOIN person.stateprovince sp ON ((sp.stateprovinceid = a.stateprovinceid)))\n     JOIN person.countryregion cr ON (((cr.countryregioncode)::text = (sp.countryregioncode)::text)))\n     JOIN person.addresstype at ON ((at.addresstypeid = bea.addresstypeid)))" Columns="s.businessentityid,s.name,addresstype,a.addressline1,a.addressline2,a.city,stateprovincename,a.postalcode,countryregionname" Tables="\Asales.store s\A,\Aperson.businessentityaddress bea\A,\Aperson.address a\A,\Aperson.stateprovince sp\A,\Aperson.countryregion cr\A,\Aperson.addresstype at\A" Temporary="0" SecurityBarrier="0" Recursive="0" Materialized="0" NoData="0" TablespaceID="0" Generate="1" ACL="" >
</VIEW>

<VIEW ID="94570" Name="vstorewithcontacts" SchemaOID="93275" SchemaName="sales" OwnerID="16393" OwnerName="pasha" XPos="2286" YPos="3790" LineColor="8388608" BackColor="12639424" FontColor="0" Comments="" Description="" Annotation="" BeginScript="" EndScript="" SQLQuery="SELECT s.businessentityid,\n    s.name,\n    ct.name AS contacttype,\n    p.title,\n    p.firstname,\n    p.middlename,\n    p.lastname,\n    p.suffix,\n    pp.phonenumber,\n    pnt.name AS phonenumbertype,\n    ea.emailaddress,\n    p.emailpromotion\n   FROM ((((((sales.store s\n     JOIN person.businessentitycontact bec ON ((bec.businessentityid = s.businessentityid)))\n     JOIN person.contacttype ct ON ((ct.contacttypeid = bec.contacttypeid)))\n     JOIN person.person p ON ((p.businessentityid = bec.personid)))\n     LEFT JOIN person.emailaddress ea ON ((ea.businessentityid = p.businessentityid)))\n     LEFT JOIN person.personphone pp ON ((pp.businessentityid = p.businessentityid)))\n     LEFT JOIN person.phonenumbertype pnt ON ((pnt.phonenumbertypeid = pp.phonenumbertypeid)))" Columns="s.businessentityid,s.name,contacttype,p.title,p.firstname,p.middlename,p.lastname,p.suffix,pp.phonenumber,phonenumbertype,ea.emailaddress,p.emailpromotion" Tables="\Asales.store s\A,\Aperson.businessentitycontact bec\A,\Aperson.contacttype ct\A,\Aperson.person p\A,\Aperson.emailaddress ea\A,\Aperson.personphone pp\A,\Aperson.phonenumbertype pnt\A" Temporary="0" SecurityBarrier="0" Recursive="0" Materialized="0" NoData="0" TablespaceID="0" Generate="1" ACL="" >
</VIEW>

<VIEW ID="94565" Name="vstorewithdemographics" SchemaOID="93275" SchemaName="sales" OwnerID="16393" OwnerName="pasha" XPos="2545" YPos="3790" LineColor="8388608" BackColor="12639424" FontColor="0" Comments="" Description="" Annotation="" BeginScript="" EndScript="" SQLQuery="SELECT store.businessentityid,\n    store.name,\n    ((unnest(xpath(\a/ns:StoreSurvey/ns:AnnualSales/text()\a::text, store.demographics, \a{{ns,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/StoreSurvey}}\a::text[])))::character varying)::money AS \AAnnualSales\A,\n    ((unnest(xpath(\a/ns:StoreSurvey/ns:AnnualRevenue/text()\a::text, store.demographics, \a{{ns,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/StoreSurvey}}\a::text[])))::character varying)::money AS \AAnnualRevenue\A,\n    (unnest(xpath(\a/ns:StoreSurvey/ns:BankName/text()\a::text, store.demographics, \a{{ns,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/StoreSurvey}}\a::text[])))::character varying(50) AS \ABankName\A,\n    (unnest(xpath(\a/ns:StoreSurvey/ns:BusinessType/text()\a::text, store.demographics, \a{{ns,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/StoreSurvey}}\a::text[])))::character varying(5) AS \ABusinessType\A,\n    ((unnest(xpath(\a/ns:StoreSurvey/ns:YearOpened/text()\a::text, store.demographics, \a{{ns,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/StoreSurvey}}\a::text[])))::character varying)::integer AS \AYearOpened\A,\n    (unnest(xpath(\a/ns:StoreSurvey/ns:Specialty/text()\a::text, store.demographics, \a{{ns,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/StoreSurvey}}\a::text[])))::character varying(50) AS \ASpecialty\A,\n    ((unnest(xpath(\a/ns:StoreSurvey/ns:SquareFeet/text()\a::text, store.demographics, \a{{ns,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/StoreSurvey}}\a::text[])))::character varying)::integer AS \ASquareFeet\A,\n    (unnest(xpath(\a/ns:StoreSurvey/ns:Brands/text()\a::text, store.demographics, \a{{ns,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/StoreSurvey}}\a::text[])))::character varying(30) AS \ABrands\A,\n    (unnest(xpath(\a/ns:StoreSurvey/ns:Internet/text()\a::text, store.demographics, \a{{ns,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/StoreSurvey}}\a::text[])))::character varying(30) AS \AInternet\A,\n    ((unnest(xpath(\a/ns:StoreSurvey/ns:NumberEmployees/text()\a::text, store.demographics, \a{{ns,http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/StoreSurvey}}\a::text[])))::character varying)::integer AS \ANumberEmployees\A\n   FROM sales.store" Columns="store.businessentityid,store.name,\A\A\AAnnualSales\A\A\A,\A\A\AAnnualRevenue\A\A\A,\A\A\ABankName\A\A\A,\A\A\ABusinessType\A\A\A,\A\A\AYearOpened\A\A\A,\A\A\ASpecialty\A\A\A,\A\A\ASquareFeet\A\A\A,\A\A\ABrands\A\A\A,\A\A\AInternet\A\A\A,\A\A\ANumberEmployees\A\A\A" Tables="sales.store" Temporary="0" SecurityBarrier="0" Recursive="0" Materialized="0" NoData="0" TablespaceID="0" Generate="1" ACL="" >
</VIEW>

