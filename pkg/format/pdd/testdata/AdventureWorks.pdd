<ENTITY ID="92929" Name="billofmaterials" SchemaOID="92926" SchemaName="production" OwnerID="16393" OwnerName="pasha" TablespaceID="0" XPos="1210" YPos="1480" Temporary="0" Unlogged="0" OnCommit="" Inherits="" FillColor="16777215" LineColor="8388608" FontColor="0" CharacterSet="" Collate="" Comments="Items required to make bicycles and bicycle subassemblies. It identifies the heirarchical relationship between a parent product and its components." Description="" Annotation="" BeginScript="" EndScript="" Generate="1" ACL="" StorageParams="OIDS=False\n" >
	<COLUMNS>
		<COLUMN ID="110" Name="billofmaterialsid" Pos="1" Datatype="23" Type="int4" Width="0" Prec="0" NotNull="1" AutoInc="1" Collation="" PrimaryKey="1" IsFKey="0" DefaultValue="" QuoteDefault="0" Comments="Primary key for BillOfMaterials records."></COLUMN>
