<ENTITY ID="93231" Name="purchaseorderheader" SchemaOID="93201" SchemaName="purchasing" OwnerID="16393" OwnerName="pasha" TablespaceID="0" XPos="2170" YPos="1810" Temporary="0" Unlogged="0" OnCommit="" Inherits="" FillColor="16777215" LineColor="8388608" FontColor="0" CharacterSet="" Collate="" Comments="General purchase order information. See PurchaseOrderDetail." Description="" Annotation="" BeginScript="" EndScript="" Generate="1" ACL="" StorageParams="OIDS=False\n" >
