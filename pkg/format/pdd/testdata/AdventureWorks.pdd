		<COLUMN ID="112" Name="componentid" Pos="3" Datatype="23" Type="int4" Width="0" Prec="0" NotNull="1" AutoInc="0" Collation="" PrimaryKey="0" IsFKey="1" DefaultValue="" QuoteDefault="0" Comments="Component identification number. Foreign key to Product.ProductID."></COLUMN>
