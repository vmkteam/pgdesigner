		<COLUMN ID="116" Name="bomlevel" Pos="7" Datatype="21" Type="int2" Width="0" Prec="0" NotNull="1" AutoInc="0" Collation="" PrimaryKey="0" IsFKey="0" DefaultValue="" QuoteDefault="0" Comments="Indicates the depth the component is from its parent (AssemblyID)."></COLUMN>
