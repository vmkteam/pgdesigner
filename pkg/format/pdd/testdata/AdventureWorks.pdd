		<COLUMN ID="367" Name="onlineorderflag" Pos="7" Datatype="92742" Type="\AFlag\A" Width="0" Prec="0" NotNull="1" AutoInc="0" Collation="" PrimaryKey="0" IsFKey="0" DefaultValue="true" QuoteDefault="0" Comments="0 = Order placed by sales person. 1 = Order placed online by customer."></COLUMN>
		<COLUMN ID="368" Name="purchaseordernumber" Pos="8" Datatype="92740" Type="\AOrderNumber\A" Width="0" Prec="0" NotNull="0" AutoInc="0" Collation="" PrimaryKey="0" IsFKey="0" DefaultValue="" QuoteDefault="0" Comments="Customer purchase order number reference."></COLUMN>
