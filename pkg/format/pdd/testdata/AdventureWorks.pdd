<ENTITY ID="93336" Name="salesorderheader" SchemaOID="93275" SchemaName="sales" OwnerID="16393" OwnerName="pasha" TablespaceID="0" XPos="1850" YPos="930" Temporary="0" Unlogged="0" OnCommit="" Inherits="" FillColor="16777215" LineColor="8388608" FontColor="0" CharacterSet="" Collate="" Comments="General sales order information." Description="" Annotation="" BeginScript="" EndScript="" Generate="1" ACL="" StorageParams="OIDS=False\n" >
