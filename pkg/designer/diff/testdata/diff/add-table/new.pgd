<?xml version="1.0" encoding="UTF-8"?>
<pgd version="1" pg-version="18" default-schema="public">
  <schema name="public">
    <table name="users">
      <column name="id" type="integer" nullable="false">
        <identity generated="by-default"></identity>
      </column>
      <column name="name" type="varchar" length="255" nullable="false"></column>
      <column name="createdAt" type="timestamptz" nullable="false" default="now()"></column>
      <pk name="pk_users">
        <column name="id"></column>
      </pk>
    </table>
    <table name="notifications">
      <column name="notificationId" type="integer" nullable="false">
        <identity generated="by-default"></identity>
      </column>
      <column name="userId" type="integer" nullable="false"></column>
      <column name="message" type="text" nullable="false"></column>
      <column name="payload" type="jsonb" nullable="false" default="'{}'"></column>
      <column name="createdAt" type="timestamptz" nullable="false" default="now()"></column>
      <column name="readAt" type="timestamptz"></column>
      <column name="statusId" type="integer" nullable="false"></column>
      <pk name="pk_notifications">
        <column name="notificationId"></column>
      </pk>
    </table>
    <index name="ix_notifications_userId" table="notifications" unique="true">
      <column name="userId"></column>
      <column name="statusId"></column>
    </index>
  </schema>
</pgd>
