    <table name="payment">
      <column name="payment_id" type="integer" nullable="false" default="nextval(&#39;public.payment_payment_id_seq&#39;::regclass)"></column>
      <column name="customer_id" type="integer" nullable="false"></column>
      <column name="staff_id" type="integer" nullable="false"></column>
      <column name="rental_id" type="integer" nullable="false"></column>
      <column name="amount" type="numeric" precision="5" scale="2" nullable="false"></column>
      <column name="payment_date" type="timestamptz" nullable="false"></column>
      <pk name="">
        <column name="payment_date"></column>
        <column name="payment_id"></column>
      </pk>
      <partition-by type="range">
        <column name="payment_date"></column>
      </partition-by>
      <partition name="payment_p2022_01">
        <bound>FOR VALUES FROM (&#39;2022-01-01 00:00:00+00&#39;) TO (&#39;2022-02-01 00:00:00+00&#39;)</bound>
      </partition>
      <partition name="payment_p2022_02">
        <bound>FOR VALUES FROM (&#39;2022-02-01 00:00:00+00&#39;) TO (&#39;2022-03-01 00:00:00+00&#39;)</bound>
      </partition>
      <partition name="payment_p2022_03">
        <bound>FOR VALUES FROM (&#39;2022-03-01 00:00:00+00&#39;) TO (&#39;2022-04-01 01:00:00+01&#39;)</bound>
      </partition>
      <partition name="payment_p2022_04">
        <bound>FOR VALUES FROM (&#39;2022-04-01 01:00:00+01&#39;) TO (&#39;2022-05-01 01:00:00+01&#39;)</bound>
      </partition>
      <partition name="payment_p2022_05">
        <bound>FOR VALUES FROM (&#39;2022-05-01 01:00:00+01&#39;) TO (&#39;2022-06-01 01:00:00+01&#39;)</bound>
      </partition>
      <partition name="payment_p2022_06">
        <bound>FOR VALUES FROM (&#39;2022-06-01 01:00:00+01&#39;) TO (&#39;2022-07-01 01:00:00+01&#39;)</bound>
      </partition>
      <partition name="payment_p2022_07">
        <bound>FOR VALUES FROM (&#39;2022-07-01 01:00:00+01&#39;) TO (&#39;2022-08-01 01:00:00+01&#39;)</bound>
      </partition>
    </table>
    <table name="rental">
