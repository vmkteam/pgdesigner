<?xml version="1.0" encoding="UTF-8"?>
<pgd version="1" pg-version="18" default-schema="public">
  <project name="pagila">
    <settings>
      <naming convention="camelCase"></naming>
      <defaults nullable="true" on-delete="restrict" on-update="restrict"></defaults>
    </settings>
  </project>
  <roles></roles>
  <tablespaces></tablespaces>
  <extensions></extensions>
  <types>
    <enum name="mpaa_rating">
      <label>G</label>
      <label>PG</label>
      <label>PG-13</label>
      <label>R</label>
      <label>NC-17</label>
    </enum>
    <domain name="bıgınt" type="bigint"></domain>
    <domain name="year" type="integer">
      <constraint name="year_check"><![CDATA[value >= 1901 AND value <= 2155]]></constraint>
    </domain>
  </types>
  <sequences>
    <sequence name="customer_customer_id_seq" schema="public" start="1" increment="1" cache="1"></sequence>
    <sequence name="actor_actor_id_seq" schema="public" start="1" increment="1" cache="1"></sequence>
    <sequence name="category_category_id_seq" schema="public" start="1" increment="1" cache="1"></sequence>
    <sequence name="film_film_id_seq" schema="public" start="1" increment="1" cache="1"></sequence>
    <sequence name="address_address_id_seq" schema="public" start="1" increment="1" cache="1"></sequence>
    <sequence name="city_city_id_seq" schema="public" start="1" increment="1" cache="1"></sequence>
    <sequence name="country_country_id_seq" schema="public" start="1" increment="1" cache="1"></sequence>
    <sequence name="inventory_inventory_id_seq" schema="public" start="1" increment="1" cache="1"></sequence>
    <sequence name="language_language_id_seq" schema="public" start="1" increment="1" cache="1"></sequence>
    <sequence name="payment_payment_id_seq" schema="public" start="1" increment="1" cache="1"></sequence>
    <sequence name="rental_rental_id_seq" schema="public" start="1" increment="1" cache="1"></sequence>
    <sequence name="staff_staff_id_seq" schema="public" start="1" increment="1" cache="1"></sequence>
    <sequence name="store_store_id_seq" schema="public" start="1" increment="1" cache="1"></sequence>
  </sequences>
